page {
  background-color: #f0f3f8;
  height: 100vh;
  overflow: hidden;
}

view,
scroll-view,
text {
  box-sizing: border-box;
}

.font-serif {
  font-family: Georgia, "Times New Roman", serif, "PingFang SC", "Microsoft YaHei";
}

.font-sans {
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, "PingFang SC", "Microsoft YaHei", sans-serif;
}

.module-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f0f3f8;
  color: #5a6a85;
}

.status-bar {
  width: 100%;
  flex-shrink: 0;
}

.module-header {
  padding: 8px 24px 24px;
  border-bottom: none;
  flex-shrink: 0;
  animation: slideUpFade 0.7s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}

.header-top {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 16px;
}

.back-btn {
  width: 48px;
  height: 48px;
  border-radius: 18px;
  border: none;
  background-color: #f0f3f8;
  box-shadow: 5px 5px 10px #d9dfe9, -5px -5px 10px #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
  color: #7a8b9e;
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.back-btn:active {
  transform: scale(0.9);
  color: #7a8b9e;
  background-color: #f0f3f8;
  box-shadow: inset 4px 4px 8px #d9dfe9, inset -4px -4px 8px #ffffff;
}

.module-eyebrow {
  display: block;
  font-size: 10px;
  color: #7a8b9e;
  letter-spacing: 3px;
  text-transform: uppercase;
  margin-bottom: 4px;
}

.module-title {
  display: block;
  font-size: 34px;
  line-height: 1.2;
  font-weight: 700;
  color: #5a6a85;
}

.module-desc {
  display: block;
  margin-top: 10px;
  font-size: 13px;
  line-height: 1.6;
  color: #7a8b9e;
  font-weight: 500;
}

.module-scroll {
  flex: 1;
  height: 0;
}

.no-scrollbar::-webkit-scrollbar {
  display: none;
}

.content {
  padding: 20px 24px 32px;
}

.summary-row {
  display: flex;
  gap: 12px;
  margin-bottom: 20px;
}

.summary-item {
  flex: 1;
  background-color: #f0f3f8;
  border: none;
  border-radius: 24px;
  padding: 18px 12px;
  box-shadow: 8px 8px 16px #d9dfe9, -8px -8px 16px #ffffff;
}

.summary-value {
  display: block;
  font-size: 24px;
  line-height: 1;
  font-weight: 700;
  color: #5a6a85;
  margin-bottom: 8px;
}

.summary-label {
  display: block;
  font-size: 11px;
  color: #7a8b9e;
}

.record-list {
  display: flex;
  flex-direction: column;
}

.record-card {
  padding: 22px;
  margin-bottom: 18px;
  border-bottom: none;
  border-radius: 24px;
  background-color: #f0f3f8;
  box-shadow: 8px 8px 16px #d9dfe9, -8px -8px 16px #ffffff;
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.record-card:active {
  transform: scale(0.98);
  box-shadow: inset 4px 4px 8px #d9dfe9, inset -4px -4px 8px #ffffff;
}

.record-top {
  display: flex;
  justify-content: space-between;
  gap: 16px;
  align-items: flex-start;
  margin-bottom: 10px;
}

.record-title {
  flex: 1;
  font-size: 18px;
  line-height: 1.4;
  font-weight: 700;
  color: #5a6a85;
}

.record-badge {
  flex-shrink: 0;
  padding: 4px 10px;
  border: none;
  border-radius: 999px;
  font-size: 10px;
  font-weight: 700;
  color: #ffffff;
  background-color: #ff9a9e;
  box-shadow: inset 3px 3px 6px #e68b8e, inset -3px -3px 6px #ffabae;
}

.record-meta,
.record-desc {
  display: block;
  font-size: 12px;
  line-height: 1.7;
  color: #7a8b9e;
}

.record-desc {
  margin-top: 8px;
  color: #7a8b9e;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-top: 12px;
}

.tag {
  padding: 4px 9px;
  background-color: #f0f3f8;
  font-size: 11px;
  color: #7a8b9e;
  border-radius: 12px;
  box-shadow: 4px 4px 8px #d9dfe9, -4px -4px 8px #ffffff;
}

.card-actions {
  display: flex;
  gap: 12px;
  margin-top: 16px;
}

.text-btn,
.solid-btn,
.outline-btn {
  min-height: 36px;
  padding: 0 16px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 13px;
  font-weight: 600;
  border-radius: 18px;
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.text-btn {
  color: #7a8b9e;
  padding-left: 0;
}

.solid-btn {
  background-color: #a1c4fd;
  color: #ffffff;
  box-shadow: 8px 8px 20px #c2d8ff, -8px -8px 20px #ffffff;
}

.outline-btn {
  border: none;
  color: #7a8b9e;
  background-color: #f0f3f8;
  box-shadow: 4px 4px 8px #d9dfe9, -4px -4px 8px #ffffff;
}

.solid-btn:active,
.outline-btn:active {
  transform: scale(0.95);
  box-shadow: inset 4px 4px 8px #d9dfe9, inset -4px -4px 8px #ffffff;
}

.empty-state {
  padding: 80px 0 24px;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.empty-mark {
  width: 56px;
  height: 56px;
  border-radius: 50%;
  border: none;
  background-color: #f0f3f8;
  box-shadow: 8px 8px 16px #d9dfe9, -8px -8px 16px #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20px;
  font-size: 24px;
  font-weight: 700;
  color: #5a6a85;
}

.empty-title {
  font-size: 18px;
  font-weight: 700;
  color: #5a6a85;
  margin-bottom: 8px;
}

.empty-desc {
  width: 80%;
  font-size: 13px;
  line-height: 1.7;
  color: #7a8b9e;
  margin-bottom: 24px;
}

.setting-list {
  display: flex;
  flex-direction: column;
}

.setting-item {
  min-height: 60px;
  padding: 18px 20px;
  margin-bottom: 16px;
  border-bottom: none;
  border-radius: 22px;
  background-color: #f0f3f8;
  box-shadow: 8px 8px 16px #d9dfe9, -8px -8px 16px #ffffff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20px;
}

.setting-item:active {
  transform: scale(0.98);
  box-shadow: inset 4px 4px 8px #d9dfe9, inset -4px -4px 8px #ffffff;
}

.setting-main {
  flex: 1;
}

.setting-title {
  display: block;
  font-size: 16px;
  font-weight: 600;
  color: #5a6a85;
  margin-bottom: 4px;
}

.setting-desc {
  display: block;
  font-size: 12px;
  color: #7a8b9e;
  line-height: 1.5;
}

.setting-action {
  color: #7a8b9e;
  font-size: 16px;
}

.danger {
  color: #dc2626;
}

@keyframes slideUpFade {
  0% { opacity: 0; transform: translateY(40px); }
  100% { opacity: 1; transform: translateY(0); }
}
