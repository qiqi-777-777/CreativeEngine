/**app.wxss**/
page {
  /* 主题色 - 页面end 极简黏土风 */
  --primary-color: #a1c4fd;
  --primary-light: #f0f3f8;
  --primary-gradient: linear-gradient(135deg, #a1c4fd 0%, #ff9a9e 100%);
  
  /* 辅助色 */
  --text-main: #5a6a85;
  --text-secondary: #7a8b9e;
  --text-muted: #a5b0c2;
  --bg-body: #f0f3f8;
  --bg-card: #f0f3f8;
  
  /* 边框与阴影 */
  --border-color: #d9dfe9;
  --clay-shadow: 12px 12px 24px #d9dfe9, -12px -12px 24px #ffffff;
  --clay-shadow-sm: 4px 4px 8px #d9dfe9, -4px -4px 8px #ffffff, inset -2px -2px 4px rgba(0, 0, 0, 0.02), inset 2px 2px 4px #ffffff;
  --clay-inset: inset 4px 4px 8px #d9dfe9, inset -4px -4px 8px #ffffff;
  --shadow-sm: var(--clay-shadow-sm);
  --shadow-md: 8px 8px 16px #d9dfe9, -8px -8px 16px #ffffff;
  --shadow-lg: var(--clay-shadow);

  background-color: var(--bg-body);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  color: var(--text-main);
  box-sizing: border-box;
  -webkit-tap-highlight-color: transparent;
}

view,
text,
input,
textarea {
  font-variant-numeric: lining-nums tabular-nums;
  font-feature-settings: "lnum" 1, "tnum" 1;
}

.service-num,
.stat-val,
.summary-value,
.summary-count,
.policy-score,
.match-badge,
.card-badge,
.detail-heat-badge,
.tag-item-tech-count,
.expert-rating,
.detail-rating,
.service-info-val,
.data-val,
.modal-stat-val,
.salary-val,
.rem-val,
.bottom-cat-val,
.info-value,
.profile-account,
.record-badge,
.card-index,
.card-no,
.req-idx,
.rem-unit,
.salary-unit {
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, Arial, "PingFang SC", "Microsoft YaHei", sans-serif !important;
  font-style: normal !important;
  font-variant-numeric: lining-nums tabular-nums;
  font-feature-settings: "lnum" 1, "tnum" 1;
  letter-spacing: 0;
}

button {
  -webkit-tap-highlight-color: transparent;
}

button::after {
  border: none;
}

::-webkit-scrollbar {
  display: none;
  width: 0;
  height: 0;
  color: transparent;
}

@keyframes slideUpFade {
  0% { opacity: 0; transform: translateY(40px); }
  100% { opacity: 1; transform: translateY(0); }
}

@keyframes popBounce {
  0% { transform: scale(0.5); opacity: 0; }
  50% { transform: scale(1.2); }
  100% { transform: scale(1); opacity: 1; }
}

.animate-slide-up-fade {
  animation: slideUpFade 0.7s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  opacity: 0;
}

.animate-pop-bounce {
  animation: popBounce 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
}

/* 全局容器 */
.container {
  min-height: 100vh;
  box-sizing: border-box;
}

/* 卡片样式 - 高保真圆角阴影 */
.card {
  background: var(--bg-card);
  border-radius: 48rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--clay-shadow);
  transition: all 0.3s ease;
}

.card:active {
  transform: scale(0.98);
  box-shadow: 6px 6px 12px #d9dfe9, -6px -6px 12px #ffffff;
}

/* 阴影提升类 */
.shadow-md { box-shadow: var(--shadow-md); }
.shadow-lg { box-shadow: var(--shadow-lg); }

/* 按钮样式 - 渐变 */
.btn-primary {
  background: var(--primary-color);
  color: #fff;
  border-radius: 40rpx;
  padding: 24rpx 48rpx;
  font-size: 30rpx;
  font-weight: 900;
  border: none;
  box-shadow: 8px 8px 20px #c2d8ff, -8px -8px 20px #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.btn-primary:active {
  transform: scale(0.95);
  box-shadow: inset 4px 4px 8px #91b0e4, inset -4px -4px 8px #b1d8ff;
}

.btn-outline {
  background: var(--bg-card);
  color: var(--text-secondary);
  border: none;
  border-radius: 32rpx;
  padding: 22rpx 48rpx;
  font-size: 30rpx;
  font-weight: 700;
  box-shadow: var(--clay-shadow-sm);
}

/* 文本实用类 */
.text-xs { font-size: 20rpx; }
.text-sm { font-size: 24rpx; }
.text-base { font-size: 28rpx; }
.text-lg { font-size: 32rpx; }
.text-xl { font-size: 36rpx; }
.text-2xl { font-size: 40rpx; }
.font-bold { font-weight: 700; }
.font-semibold { font-weight: 600; }
.font-medium { font-weight: 500; }

.text-primary { color: var(--primary-color); }
.text-main { color: var(--text-main); }
.text-secondary { color: var(--text-secondary); }
.text-muted { color: var(--text-muted); }

/* Flex 布局实用类 */
.flex { display: flex; }
.flex-col { flex-direction: column; }
.flex-row { flex-direction: row; }
.items-center { align-items: center; }
.justify-center { justify-content: center; }
.justify-between { justify-content: space-between; }
.justify-around { justify-content: space-around; }
.justify-end { justify-content: flex-end; }
.flex-1 { flex: 1; }
.flex-wrap { flex-wrap: wrap; }
.gap-1 { gap: 8rpx; }
.gap-2 { gap: 16rpx; }
.gap-3 { gap: 24rpx; }
.gap-4 { gap: 32rpx; }

/* 间距实用类 (Space) */
.m-0 { margin: 0; }
.mt-2 { margin-top: 16rpx; }
.mt-4 { margin-top: 32rpx; }
.mb-2 { margin-bottom: 16rpx; }
.mb-4 { margin-bottom: 32rpx; }
.mx-2 { margin-left: 16rpx; margin-right: 16rpx; }
.mx-4 { margin-left: 32rpx; margin-right: 32rpx; }
.my-2 { margin-top: 16rpx; margin-bottom: 16rpx; }
.my-4 { margin-top: 32rpx; margin-bottom: 32rpx; }

.p-2 { padding: 16rpx; }
.p-4 { padding: 32rpx; }
.px-4 { padding-left: 32rpx; padding-right: 32rpx; }
.py-2 { padding-top: 16rpx; padding-bottom: 16rpx; }
.py-4 { padding-top: 32rpx; padding-bottom: 32rpx; }

/* 其他实用类 */
.w-full { width: 100%; }
.h-full { height: 100%; }
.rounded-full { border-radius: 9999rpx; }
.rounded-lg { border-radius: 16rpx; }
.rounded-xl { border-radius: 24rpx; }
.opacity-90 { opacity: 0.9; }

/* 标签样式更新 */
.tag {
  display: inline-flex;
  padding: 12rpx 24rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  margin-right: 12rpx;
  font-weight: 700;
  background: var(--bg-card);
  color: var(--text-secondary);
  box-shadow: var(--clay-shadow-sm);
}

.tag-primary {
  background: var(--primary-light);
  color: var(--primary-color);
}


