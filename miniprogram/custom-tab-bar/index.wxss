/* custom-tab-bar/index.wxss */
.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: calc(96rpx + env(safe-area-inset-bottom));
  background: #f0f3f8;
  display: flex;
  box-sizing: border-box;
  padding-bottom: env(safe-area-inset-bottom);
  box-shadow: -8px -8px 18px rgba(255,255,255,0.9), 0 -8px 22px rgba(217,223,233,0.75);
  z-index: 9999;
}

.tab-bar-border {
  background-color: rgba(217, 223, 233, 0.8);
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 1px;
  transform: scaleY(0.5);
}

.tab-bar-item {
  flex: 1;
  height: 96rpx;
  text-align: center;
  display: flex;
  justify-content: center;
  align-items: center;
  flex-direction: column;
  position: relative;
  transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.tab-bar-item:active {
  transform: scale(0.92);
}

.tab-icon {
  width: 48rpx;
  height: 48rpx;
  margin-bottom: 4rpx;
}

.tab-text {
  font-size: 20rpx;
  font-weight: 700;
}

.special-item {
  position: relative;
  top: 0;
}

.special-icon-wrapper {
  width: 56rpx;
  height: 56rpx;
  border-radius: 24rpx;
  background: #f0f3f8;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 4px 4px 8px #d9dfe9, -4px -4px 8px #ffffff;
  margin-bottom: 4rpx;
}

.special-icon {
  width: 100%;
  height: 100%;
}

.special-text {
  position: relative;
  top: 0;
}
