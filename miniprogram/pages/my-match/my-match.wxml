<view class="container font-serif">
  <view class="status-bar" style="height: {{statusBarHeight}}px;"></view>

  <!-- 顶部导航 -->
  <view class="page-header">
    <text class="page-subtitle font-sans">MY MATCH</text>
    <view class="title-row">
      <view class="back-btn" bindtap="goBack">
        <text class="icon-back">←</text>
      </view>
      <text class="page-title">我的匹配</text>
    </view>
  </view>

  <!-- Tab 切换 -->
  <view class="tab-bar font-sans">
    <view class="tab-item {{activeTab === 0 ? 'active' : ''}}" bindtap="switchTab" data-tab="0">
      <text>职业匹配</text>
      <view class="tab-indicator" wx:if="{{activeTab === 0}}"></view>
    </view>
    <view class="tab-item {{activeTab === 1 ? 'active' : ''}}" bindtap="switchTab" data-tab="1">
      <text>适配政策</text>
      <view class="tab-indicator" wx:if="{{activeTab === 1}}"></view>
    </view>
  </view>

  <!-- 内容区域 -->
  <scroll-view scroll-y class="content-scroll no-scrollbar">

    <!-- 职业匹配 Tab -->
    <view wx:if="{{activeTab === 0}}">
      <view class="result-card font-sans" wx:for="{{careerResults}}" wx:key="id">
        <view class="result-header">
          <view class="match-badge">{{item.matchRate}}%</view>
          <view class="result-title-box">
            <text class="result-title">{{item.title}}</text>
            <text class="result-sub">{{item.category}}</text>
          </view>
        </view>
        <text class="result-desc">{{item.desc}}</text>
        <view class="result-tags">
          <text class="result-tag" wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this">{{tag}}</text>
        </view>
        <view class="result-footer">
          <text class="result-date">匹配于 {{item.date}}</text>
          <text class="result-arrow">›</text>
        </view>
      </view>

      <!-- 重新匹配按钮 -->
      <view class="bottom-action" bindtap="goToCareerMatch">
        <text class="action-text">重新进行职业匹配</text>
        <text class="action-arrow">→</text>
      </view>
    </view>

    <!-- 适配政策 Tab -->
    <view wx:if="{{activeTab === 1}}">
      <view class="policy-card font-sans" wx:for="{{policyResults}}" wx:key="id" bindtap="goToPolicyDetail" data-id="{{item.id}}">
        <view class="policy-top">
          <text class="policy-title">{{item.title}}</text>
          <text class="policy-amount">{{item.amount}}</text>
        </view>
        <text class="policy-summary">{{item.summary}}</text>
        <view class="policy-bottom">
          <text class="policy-source">{{item.source}}</text>
          <text class="policy-deadline">截止 {{item.deadline}}</text>
        </view>
      </view>

      <view class="empty-hint font-sans" wx:if="{{policyResults.length === 0}}">
        <text>暂无适配政策，请完善企业档案以获取更精准的推荐</text>
      </view>
    </view>

    <view style="height: 60px;"></view>
  </scroll-view>
</view>
