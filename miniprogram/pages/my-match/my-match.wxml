<view class="container font-serif">
  <view class="status-bar" style="height: {{statusBarHeight}}px;"></view>

  <view class="page-header">
    <text class="page-subtitle font-sans">MY MATCH</text>
    <view class="title-row">
      <view class="back-btn" bindtap="goBack">
        <text class="icon-back">←</text>
      </view>
      <text class="page-title">我的匹配</text>
    </view>
  </view>

  <view class="tab-bar font-sans">
    <view class="tab-item {{activeTab === 0 ? 'active' : ''}}" bindtap="switchTab" data-tab="0">
      <text>职业匹配</text>
      <view class="tab-indicator" wx:if="{{activeTab === 0}}"></view>
    </view>
    <view class="tab-item {{activeTab === 1 ? 'active' : ''}}" bindtap="switchTab" data-tab="1">
      <text>适配政策</text>
      <view class="tab-indicator" wx:if="{{activeTab === 1}}"></view>
    </view>
  </view>

  <scroll-view scroll-y class="content-scroll no-scrollbar">
    <view wx:if="{{activeTab === 0}}">
      <view class="match-summary font-sans" wx:if="{{careerResults.length > 0}}">
        <view>
          <text class="summary-title">最近一次测评</text>
          <text class="summary-desc">已根据 {{latestMatchDate}} 的结果更新</text>
        </view>
        <view class="summary-count">{{careerResults.length}} 项</view>
      </view>

      <view wx:if="{{careerResults.length === 0}}" class="empty-state font-sans">
        <view class="empty-mark">配</view>
        <text class="empty-title">暂无职业匹配结果</text>
        <text class="empty-desc">完成一次职业测评后，这里会自动展示最新推荐方向。</text>
        <view class="bottom-action compact" bindtap="goToCareerMatch">
          <text class="action-text">开始职业匹配</text>
        </view>
      </view>

      <view wx:else>
        <view class="result-card font-sans" wx:for="{{careerResults}}" wx:key="id" bindtap="openCareerResult" data-index="{{index}}">
          <view class="result-header">
            <view class="match-badge">{{item.matchRate}}%</view>
            <view class="result-title-box">
              <text class="result-title">{{item.title}}</text>
              <text class="result-sub">{{item.category}}</text>
            </view>
          </view>
          <text class="result-desc">{{item.desc}}</text>
          <view class="result-tags">
            <text class="result-tag" wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this">{{tag}}</text>
          </view>
          <view class="result-footer">
            <text class="result-date">匹配于 {{item.date}}</text>
            <text class="result-arrow">查看详情 ></text>
          </view>
        </view>

        <view class="bottom-action" bindtap="goToCareerMatch">
          <text class="action-text">重新进行职业匹配</text>
          <text class="action-arrow">→</text>
        </view>
      </view>
    </view>

    <view wx:if="{{activeTab === 1}}">
      <view class="policy-hero font-sans">
        <view>
          <text class="policy-hero-title">为你筛出 {{policyResults.length}} 条政策</text>
          <text class="policy-hero-desc">根据最近职业匹配、就业创业关键词和政策内容综合排序</text>
        </view>
        <view class="policy-refresh" bindtap="loadMatchedPolicies">刷新</view>
      </view>

      <view class="keyword-row font-sans" wx:if="{{displayPolicyKeywords.length > 0}}">
        <text class="keyword-chip" wx:for="{{displayPolicyKeywords}}" wx:key="*this">{{item}}</text>
      </view>

      <view class="loading-state font-sans" wx:if="{{policyLoading}}">
        <text>正在匹配政策...</text>
      </view>

      <view wx:if="{{!policyLoading && policyResults.length === 0}}" class="empty-state font-sans">
        <view class="empty-mark">策</view>
        <text class="empty-title">暂无适配政策</text>
        <text class="empty-desc">可以先查看政策库，或完成一次职业匹配后再回来查看。</text>
        <view class="bottom-action compact" bindtap="goToPolicyList">
          <text class="action-text">查看政策库</text>
        </view>
      </view>

      <view wx:if="{{!policyLoading && policyResults.length > 0}}" class="policy-list">
        <view class="policy-card font-sans" wx:for="{{policyResults}}" wx:key="id" bindtap="goToPolicyDetail" data-id="{{item.id}}">
          <view class="policy-top">
            <view class="policy-main">
              <text class="policy-title">{{item.title}}</text>
              <text class="policy-source">{{item.source}} · {{item.date}}</text>
            </view>
            <view class="policy-score">{{item.matchRate}}%</view>
          </view>

          <text class="policy-summary">{{item.summary}}</text>

          <view class="policy-reason">
            <text>{{item.reason}}</text>
          </view>

          <view class="policy-bottom">
            <view class="policy-tags">
              <text class="policy-tag" wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this">{{tag}}</text>
            </view>
            <text class="policy-arrow">详情 ></text>
          </view>
        </view>
      </view>
    </view>

    <view style="height: 60px;"></view>
  </scroll-view>
</view>
