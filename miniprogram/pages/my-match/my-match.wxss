/* my-match.wxss */
page { background-color: #ffffff; height: 100vh; overflow: hidden; }
.font-serif { font-family: "Georgia", "Times New Roman", serif, 'PingFang SC', 'Microsoft YaHei'; }
.font-sans { font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, 'PingFang SC', 'Microsoft YaHei', sans-serif; }
.container { display: flex; flex-direction: column; height: 100vh; background: #fff; }
.status-bar { width: 100%; flex-shrink: 0; }
.no-scrollbar::-webkit-scrollbar { display: none; }

/* Header */
.page-header { padding: 8px 24px 16px; flex-shrink: 0; box-sizing: border-box; width: 100%; }
.page-subtitle { font-size: 10px; letter-spacing: 3px; color: #9ca3af; text-transform: uppercase; display: block; margin-bottom: 4px; }
.title-row { display: flex; align-items: center; gap: 12px; }
.back-btn { width: 36px; height: 36px; border-radius: 50%; border: 1px solid #e5e7eb; display: flex; align-items: center; justify-content: center; }
.back-btn:active { background-color: #000; border-color: #000; }
.back-btn:active .icon-back { color: #fff; }
.icon-back { font-size: 18px; color: #000; }
.page-title { font-size: 28px; font-weight: bold; color: #000; }

/* Tab Bar */
.tab-bar {
  display: flex;
  padding: 0 24px;
  border-bottom: 1px solid #000;
  flex-shrink: 0;
  box-sizing: border-box;
  width: 100%;
}
.tab-item {
  flex: 1;
  text-align: center;
  padding: 14px 0;
  font-size: 15px;
  font-weight: 500;
  color: #9ca3af;
  position: relative;
  transition: all 0.3s;
}
.tab-item.active {
  color: #000;
  font-weight: 700;
}
.tab-indicator {
  position: absolute;
  bottom: -1px;
  left: 50%;
  transform: translateX(-50%);
  width: 32px;
  height: 3px;
  background-color: #000;
}

/* Content Scroll */
.content-scroll { flex: 1; height: 0; padding: 0 24px; box-sizing: border-box; width: 100%; }

/* Career Result Card */
.result-card {
  padding: 24px 0;
  border-bottom: 1px solid #f3f4f6;
}
.result-header {
  display: flex;
  align-items: center;
  gap: 16px;
  margin-bottom: 12px;
}
.match-badge {
  width: 56px;
  height: 56px;
  border-radius: 50%;
  border: 2px solid #000;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  font-weight: bold;
  color: #000;
  flex-shrink: 0;
}
.result-title-box { display: flex; flex-direction: column; }
.result-title { font-size: 18px; font-weight: 700; color: #000; margin-bottom: 2px; }
.result-sub { font-size: 12px; color: #9ca3af; }
.result-desc { font-size: 13px; color: #6b7280; line-height: 1.7; margin-bottom: 12px; }
.result-tags { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 12px; }
.result-tag {
  font-size: 11px;
  padding: 4px 12px;
  border: 1px solid #e5e7eb;
  border-radius: 999px;
  color: #374151;
}
.result-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.result-date { font-size: 11px; color: #d1d5db; }
.result-arrow { font-size: 22px; color: #d1d5db; }

/* Policy Card */
.policy-card {
  padding: 24px 0;
  border-bottom: 1px solid #f3f4f6;
}
.policy-card:active { padding-left: 8px; }
.policy-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 8px;
}
.policy-title { font-size: 16px; font-weight: 700; color: #000; flex: 1; margin-right: 12px; }
.policy-amount {
  font-size: 14px;
  font-weight: bold;
  color: #000;
  border: 1px solid #000;
  padding: 2px 10px;
  border-radius: 999px;
  white-space: nowrap;
  flex-shrink: 0;
}
.policy-summary { font-size: 13px; color: #6b7280; line-height: 1.7; margin-bottom: 12px; }
.policy-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.policy-source { font-size: 11px; color: #9ca3af; }
.policy-deadline { font-size: 11px; color: #000; font-weight: 600; }

/* Empty */
.empty-hint {
  padding: 60px 24px;
  text-align: center;
  color: #d1d5db;
  font-size: 14px;
}

/* Bottom Action */
.bottom-action {
  margin: 24px 0;
  padding: 18px;
  background-color: #000;
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 8px;
}
.bottom-action:active { opacity: 0.8; }
.action-text { font-size: 15px; color: #fff; font-weight: 600; }
.action-arrow { font-size: 16px; color: #fff; }
