<view class="module-page font-serif">
  <view class="status-bar" style="height: {{statusBarHeight}}px;"></view>

  <view class="module-header">
    <view class="header-top">
      <view class="back-btn font-sans" bindtap="goBack">←</view>
      <view>
        <text class="module-eyebrow font-sans">ACCOUNT PROFILE</text>
        <text class="module-title">账号资料</text>
      </view>
    </view>
    <text class="module-desc font-sans">完善你的基础资料，后续用于政策匹配、项目档案和资源对接。</text>
  </view>

  <scroll-view scroll-y class="module-scroll no-scrollbar">
    <view class="content font-sans">
      <view class="profile-card">
        <view class="profile-avatar" bindtap="chooseAvatar">
          <image wx:if="{{form.avatar}}" class="profile-avatar-image" src="{{form.avatar}}" mode="aspectFill"></image>
          <text wx:else>{{avatarLetter}}</text>
          <view class="avatar-edit-badge">更换</view>
        </view>
        <view class="profile-main">
          <text class="profile-name">{{form.nickname || form.username || '未命名用户'}}</text>
          <text class="profile-account">账号：{{form.username || '-'}}</text>
        </view>
      </view>

      <view class="form-panel">
        <view class="field-item">
          <text class="field-label">用户名</text>
          <input class="field-input readonly" value="{{form.username}}" disabled />
          <text class="field-hint">用户名用于登录，暂不支持修改</text>
        </view>

        <view class="field-item">
          <text class="field-label">昵称</text>
          <input class="field-input" placeholder="请输入昵称" value="{{form.nickname}}" bindinput="onInput" data-field="nickname" maxlength="20" />
        </view>

        <view class="field-item">
          <text class="field-label">手机号</text>
          <input class="field-input" type="number" placeholder="请输入手机号" value="{{form.phone}}" bindinput="onInput" data-field="phone" maxlength="11" />
        </view>

        <view class="field-item">
          <text class="field-label">邮箱</text>
          <input class="field-input" placeholder="请输入邮箱" value="{{form.email}}" bindinput="onInput" data-field="email" maxlength="60" />
        </view>

        <view class="field-item">
          <text class="field-label">身份标签</text>
          <picker mode="selector" range="{{roleOptions}}" value="{{roleIndex}}" bindchange="onRoleChange">
            <view class="picker-field">
              <text>{{form.role || '请选择身份标签'}}</text>
              <text class="picker-arrow">></text>
            </view>
          </picker>
          <text class="field-hint">用于后续优化创业、就业和政策推荐</text>
        </view>
      </view>

      <view class="info-panel">
        <view class="info-row">
          <text class="info-label">用户 ID</text>
          <text class="info-value">{{form.id || '-'}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">账号状态</text>
          <text class="info-value">{{statusText}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">最近同步</text>
          <text class="info-value">{{lastSyncText}}</text>
        </view>
      </view>

      <view class="fixed-actions">
        <view class="outline-btn" bindtap="resetForm">恢复</view>
        <view class="solid-btn" bindtap="saveProfile">保存资料</view>
      </view>

      <view style="height: 40px;"></view>
    </view>
  </scroll-view>
</view>
