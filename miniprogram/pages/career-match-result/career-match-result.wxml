<!--pages/career-match-result/career-match-result.wxml-->
<view class="container">
  <!-- Top Navigation -->
  <view class="nav-bar">
    <view class="back-btn" bindtap="goBack">
      <view class="icon-chevron-left"></view>
    </view>
  </view>

  <scroll-view scroll-y class="main-content">
    <!-- Editorial Header Section -->
    <view class="header-section">
      <view class="header-icon-wrap">
        <view class="css-target"></view>
      </view>
      <view class="header-title">为您匹配到 {{occupations.length}} 个职业</view>
      <view class="header-subtitle">Recommendations aligned with your competencies & traits.</view>
    </view>

    <!-- Results List -->
    <view class="results-list">
      <view class="result-card" wx:for="{{occupations}}" wx:key="id">
        <!-- Title & Badge -->
        <view class="card-top">
          <view class="card-title-area">
            <view class="card-index-wrap">
              <text class="card-index">0{{index + 1}}</text>
              <text class="card-en">CAREER RECOMMENDATION</text>
            </view>
            <view class="card-title">{{item.name}}</view>
          </view>
          <view class="card-badge">{{item.industryHeat || 'A'}}</view>
        </view>

        <!-- Tags Area -->
        <view class="tags-area">
          <!-- Majors -->
          <view class="tag-group" wx:if="{{item.majors && item.majors.length > 0}}">
            <view class="tag-label"><view class="icon-lucide icon-graduation-cap"></view>匹配专业</view>
            <view class="tag-list">
              <text class="tag-item-major" wx:for="{{item.majors}}" wx:key="*this" wx:for-item="major">{{major}}</text>
            </view>
          </view>

          <!-- Tech -->
          <view class="tag-group" wx:if="{{item.skills && item.skills.length > 0}}">
            <view class="tag-label"><view class="icon-lucide icon-terminal"></view>技术要求</view>
            <view class="tag-list">
              <text class="tag-item-tech" wx:for="{{item.skills.length > 2 ? [item.skills[0], item.skills[1]] : item.skills}}" wx:key="*this" wx:for-item="skill">{{skill}}</text>
              <text class="tag-item-tech-count" wx:if="{{item.skills.length > 2}}">+{{item.skills.length - 2}}</text>
            </view>
          </view>

          <!-- Personality -->
          <view class="tag-group">
            <view class="tag-label"><view class="icon-lucide icon-user-square"></view>适合性格</view>
            <view class="tag-personality">{{item.personalityCode}}型</view>
          </view>
        </view>

        <!-- Reason & Action -->
        <view class="reason-action-box">
          <view class="reason-border"></view>
          <view class="reason-text">"{{item.reason}}"</view>
          <view class="action-btn-wrap">
            <view class="action-btn" bindtap="viewOccupationDetail" data-occupation="{{item}}">
              READ MORE <text class="icon-arrow-right">→</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="bottom-spacer" style="height: 100rpx;"></view>
  </scroll-view>

  <!-- Career Detail Modal -->
  <view class="modal-overlay" bindtap="hideDetail" wx:if="{{showDetailModal}}">
    <view class="modal-content" catchtap="stopPropagation">
      <!-- Modal Header -->
      <view class="modal-header">
        <view class="modal-header-info">
          <view class="modal-en">CAREER DETAIL</view>
          <view class="modal-title">{{selectedOccupation.name}}</view>
        </view>
        <view class="modal-close" bindtap="hideDetail">✕</view>
      </view>

      <!-- Modal Body -->
      <scroll-view scroll-y class="modal-body">
        <view class="detail-section">
          <view class="detail-section-title"><view class="icon-lucide icon-briefcase"></view>职业概述</view>
          <view class="detail-section-content overview-text">{{selectedOccupation.description || '该职业在行业中扮演重要角色，负责企业品牌传播与用户增长，需要敏锐的网感、扎实的文案功底以及数据分析技能。'}}</view>
        </view>

        <view class="detail-section" wx:if="{{selectedOccupation.majors && selectedOccupation.majors.length > 0}}">
          <view class="detail-section-title"><view class="icon-lucide icon-graduation-cap"></view>匹配专业</view>
          <view class="detail-tags-wrap">
            <text class="detail-tag-major" wx:for="{{selectedOccupation.majors}}" wx:key="*this">{{item}}</text>
          </view>
        </view>

        <view class="detail-section" wx:if="{{selectedOccupation.skills && selectedOccupation.skills.length > 0}}">
          <view class="detail-section-title"><view class="icon-lucide icon-terminal"></view>技术要求</view>
          <view class="detail-tags-wrap">
            <text class="detail-tag-tech" wx:for="{{selectedOccupation.skills}}" wx:key="*this">{{item}}</text>
          </view>
        </view>

        <view class="detail-section">
          <view class="detail-section-title"><view class="icon-lucide icon-user-square"></view>适合性格</view>
          <view class="detail-personality">{{selectedOccupation.personalityCode}}型</view>
        </view>

        <view class="detail-section">
          <view class="detail-section-title"><view class="icon-lucide icon-trending-up"></view>职业发展</view>
          <view class="detail-section-content development-text">{{selectedOccupation.careerPath || '该职业具有良好的发展前景，可以向高级运营、增长黑客或CMO岗位晋升，薪资待遇随经验呈指数级增长。'}}</view>
        </view>

        <view class="detail-section">
          <view class="detail-section-title"><view class="icon-lucide icon-lightbulb"></view>推荐理由</view>
          <view class="detail-reason-box">
            <view class="detail-reason-text">{{selectedOccupation.reason}}</view>
          </view>
        </view>

        <view class="detail-section">
          <view class="detail-section-title"><view class="icon-lucide icon-flame"></view>行业热度</view>
          <view class="detail-heat-wrap">
            <view class="detail-heat-badge">{{selectedOccupation.industryHeat || 'A'}}</view>
            <view class="detail-heat-desc">
              <text wx:if="{{selectedOccupation.industryHeat === 'A'}}">非常热门，需求旺盛</text>
              <text wx:elif="{{selectedOccupation.industryHeat === 'B'}}">较热门，就业机会多</text>
              <text wx:elif="{{selectedOccupation.industryHeat === 'C'}}">一般，稳定发展</text>
              <text wx:else>冷门，竞争小</text>
            </view>
          </view>
        </view>

        <view class="modal-bottom-padding"></view>
      </scroll-view>
    </view>
  </view>
</view>
