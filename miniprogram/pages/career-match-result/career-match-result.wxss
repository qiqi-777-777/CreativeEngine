/* container */
page {
  background: #fff;
  height: 100%;
}

.container {
  width: 100%;
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #fff;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
  color: #000;
}

/* Nav Bar */
.nav-bar {
  padding: 30rpx 40rpx 16rpx;
  display: flex;
  align-items: center;
  position: relative;
  z-index: 40;
}

.back-btn {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: -16rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.back-btn:active {
  border-color: #e5e7eb;
}

.icon-chevron-left {
  width: 24rpx;
  height: 24rpx;
  border-top: 4rpx solid #000;
  border-left: 4rpx solid #000;
  transform: rotate(-45deg);
}

.main-content {
  flex: 1;
  height: 0; /* needed for scroll-view */
}

/* Header Section */
.header-section {
  padding: 48rpx 56rpx 80rpx;
  border-bottom: 4rpx solid #000;
}

.header-icon-wrap {
  display: flex;
  justify-content: center;
  margin-bottom: 48rpx;
}

.css-target {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid #000;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.css-target::after {
  content: "";
  width: 32rpx;
  height: 32rpx;
  background-color: #000;
  border-radius: 50%;
}

.header-title {
  font-size: 68rpx;
  font-family: Georgia, 'Times New Roman', Times, serif;
  font-weight: bold;
  color: #000;
  line-height: 1.2;
  letter-spacing: -1rpx;
  text-align: center;
  margin-bottom: 24rpx;
}

.header-subtitle {
  font-size: 26rpx;
  color: #6b7280;
  font-family: Georgia, 'Times New Roman', Times, serif;
  font-style: italic;
  text-align: center;
  letter-spacing: 1rpx;
}

/* Results List */
.results-list {
  display: flex;
  flex-direction: column;
}

.result-card {
  border-bottom: 2rpx solid #000;
  padding: 64rpx 56rpx;
  transition: background-color 0.3s;
}

.result-card:active {
  background-color: rgba(249, 250, 251, 0.5);
}

.card-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 48rpx;
}

.card-title-area {
  flex: 1;
}

.card-index-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.card-index {
  font-size: 20rpx;
  font-family: Georgia, 'Times New Roman', Times, serif;
  color: #9ca3af;
  font-style: italic;
}

.card-en {
  font-size: 20rpx;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: #6b7280;
}

.card-title {
  font-size: 52rpx;
  font-weight: bold;
  color: #000;
  letter-spacing: -1rpx;
}

.card-badge {
  width: 72rpx;
  height: 72rpx;
  border: 4rpx solid #000;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: Georgia, 'Times New Roman', Times, serif;
  font-weight: bold;
  font-size: 30rpx;
  box-sizing: border-box;
}

/* Tags Area */
.tags-area {
  margin-bottom: 64rpx;
}

.tag-group {
  margin-bottom: 40rpx;
}

.tag-label {
  font-size: 24rpx;
  font-weight: bold;
  color: #000;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
}

.tag-list {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.tag-item-major {
  padding: 8rpx 20rpx;
  border: 2rpx solid #d1d5db;
  font-size: 22rpx;
  color: #374151;
  border-radius: 4rpx;
}

.tag-item-tech {
  padding: 8rpx 20rpx;
  background-color: #f3f4f6;
  font-size: 22rpx;
  color: #4b5563;
  border-radius: 4rpx;
}

.tag-item-tech-count {
  padding: 8rpx 20rpx;
  border: 2rpx dashed #9ca3af;
  font-size: 22rpx;
  color: #6b7280;
  border-radius: 4rpx;
  font-family: monospace;
}

.tag-personality {
  padding: 8rpx 24rpx;
  background-color: #000;
  color: #fff;
  font-size: 22rpx;
  font-weight: bold;
  letter-spacing: 2rpx;
  text-transform: uppercase;
  display: inline-block;
}

/* Reason & Action */
.reason-action-box {
  background-color: #fff;
  border: 2rpx solid #e5e7eb;
  padding: 40rpx;
  position: relative;
}

.reason-border {
  position: absolute;
  top: 0;
  left: 0;
  width: 8rpx;
  height: 100%;
  background-color: #000;
}

.reason-text {
  font-size: 26rpx;
  color: #4b5563;
  line-height: 1.6;
  font-family: Georgia, 'Times New Roman', Times, serif;
  font-style: italic;
  margin-bottom: 40rpx;
}

.action-btn-wrap {
  display: flex;
  justify-content: flex-end;
}

.action-btn {
  font-size: 24rpx;
  font-weight: bold;
  color: #000;
  text-transform: uppercase;
  letter-spacing: 2rpx;
  border-bottom: 2rpx solid #000;
  padding-bottom: 4rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  transition: padding-right 0.3s;
}

.action-btn:active {
  padding-right: 16rpx;
}

.icon-arrow-right {
  font-family: Arial, Helvetica, sans-serif;
  font-size: 28rpx;
  margin-left: 8rpx;
  line-height: 1;
}

/* Modal */
@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.3);
  z-index: 999;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  animation: fadeIn 0.3s ease-out forwards;
}

.modal-content {
  width: 100%;
  height: 88%;
  background-color: #fff;
  border-radius: 48rpx 48rpx 0 0;
  border-top: 2rpx solid #000;
  display: flex;
  flex-direction: column;
  box-shadow: 0 -40rpx 80rpx rgba(0, 0, 0, 0.15);
  animation: slideUp 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}

.modal-header {
  width: 100%;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 56rpx;
  border-bottom: 2rpx solid #000;
  flex-shrink: 0;
  box-sizing: border-box;
}

.modal-header-info {
  flex: 1;
}

.modal-en {
  font-size: 20rpx;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  letter-spacing: 0.2em;
  color: #9ca3af;
  text-transform: uppercase;
  margin-bottom: 8rpx;
}

.modal-title {
  font-size: 52rpx;
  font-family: Georgia, 'Times New Roman', Times, serif;
  font-weight: bold;
  color: #000;
  line-height: 1.1;
  letter-spacing: -1rpx;
}

.modal-close {
  padding: 16rpx;
  border: 2rpx solid #e5e7eb;
  color: #000;
  font-size: 32rpx;
  line-height: 1;
  margin-top: 8rpx;
  transition: border-color 0.3s;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
  box-sizing: border-box;
}

.modal-close:active {
  border-color: #000;
}

.modal-body {
  flex: 1;
  padding: 64rpx 56rpx;
  box-sizing: border-box;
  height: 0;
}

.detail-section {
  margin-bottom: 64rpx;
}

.detail-section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #000;
  letter-spacing: 1rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
}

.detail-section-content {
  padding-left: 48rpx;
  font-size: 28rpx;
  color: #4b5563;
  line-height: 1.6;
}

.overview-text {
  font-family: Georgia, 'Times New Roman', Times, serif;
  font-style: italic;
  color: #374151;
}

.development-text {
  text-align: justify;
}

.detail-tags-wrap {
  padding-left: 48rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.detail-tag-major {
  padding: 12rpx 24rpx;
  border: 2rpx solid #d1d5db;
  font-size: 24rpx;
  font-weight: 500;
  color: #000;
}

.detail-tag-tech {
  padding: 12rpx 24rpx;
  border: 2rpx solid rgba(0, 0, 0, 0.1);
  background-color: #f9fafb;
  font-size: 24rpx;
  color: #374151;
}

.detail-personality {
  margin-left: 48rpx;
  padding: 16rpx 32rpx;
  background-color: #000;
  color: #fff;
  font-size: 26rpx;
  font-weight: bold;
  letter-spacing: 2rpx;
  text-transform: uppercase;
  display: inline-block;
}

.detail-reason-box {
  margin-left: 48rpx;
  border-left: 4rpx solid #000;
  padding-left: 32rpx;
  padding-top: 8rpx;
  padding-bottom: 8rpx;
}

.detail-reason-text {
  font-family: Georgia, 'Times New Roman', Times, serif;
  font-style: italic;
  color: #000;
  font-weight: 500;
  font-size: 28rpx;
  line-height: 1.6;
}

.detail-heat-wrap {
  margin-left: 48rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.detail-heat-badge {
  width: 64rpx;
  height: 64rpx;
  border: 4rpx solid #000;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: Georgia, 'Times New Roman', Times, serif;
  font-weight: bold;
  color: #000;
  font-size: 32rpx;
  box-sizing: border-box;
}

.detail-heat-desc {
  font-size: 28rpx;
  color: #4b5563;
  font-weight: 500;
}

.modal-bottom-padding {
  height: 80rpx;
}

/* Lucide Icons CSS */
.icon-lucide {
  width: 28rpx;
  height: 28rpx;
  display: inline-block;
  background-size: contain;
  background-repeat: no-repeat;
  background-position: center;
  margin-right: 12rpx;
  vertical-align: text-bottom;
}

.detail-section-title .icon-lucide {
