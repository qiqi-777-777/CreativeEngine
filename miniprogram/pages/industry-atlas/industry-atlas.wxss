/* industry-atlas.wxss */
page {
  background-color: #ffffff;
  height: 100vh;
  overflow: hidden;
}

.font-serif { font-family: "Georgia", "Times New Roman", serif, 'PingFang SC', 'Microsoft YaHei'; }
.font-sans { font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, 'PingFang SC', 'Microsoft YaHei', sans-serif; }

.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #fff;
}

.status-bar { width: 100%; flex-shrink: 0; }

.no-scrollbar::-webkit-scrollbar { display: none; }

/* Header */
.page-header {
  padding: 8px 24px 16px;
  flex-shrink: 0;
}

.page-subtitle {
  font-size: 10px;
  letter-spacing: 3px;
  color: #9ca3af;
  text-transform: uppercase;
  display: block;
  margin-bottom: 4px;
}

.title-row {
  display: flex;
  align-items: center;
  gap: 12px;
}

.back-btn {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  border: 1px solid #e5e7eb;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-btn:active {
  background-color: #000;
  border-color: #000;
  color: #fff;
}

.icon-back {
  font-size: 18px;
  color: #000;
}

.back-btn:active .icon-back {
  color: #fff;
}

.page-title {
  font-size: 28px;
  font-weight: bold;
  color: #000;
}

/* Category Scroll */
.category-scroll {
  padding: 0 24px 16px;
  flex-shrink: 0;
  white-space: nowrap;
  border-bottom: 1px solid #000;
}

.category-row {
  display: inline-flex;
  gap: 10px;
}

.category-tag {
  display: inline-flex;
  padding: 8px 20px;
  border: 1px solid #e5e7eb;
  border-radius: 999px;
  font-size: 13px;
  color: #6b7280;
  white-space: nowrap;
  transition: all 0.3s;
}

.category-tag.active {
  background-color: #000;
  border-color: #000;
  color: #fff;
}

/* Content Scroll */
.content-scroll {
  flex: 1;
  height: 0;
}

/* Section Block */
.section-block {
  padding: 24px;
  border-bottom: 1px solid #f3f4f6;
}

.section-label-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: 16px;
}

.section-label {
  font-size: 20px;
  font-weight: bold;
  color: #000;
}

.section-en {
  font-size: 10px;
  color: #9ca3af;
  text-transform: uppercase;
  letter-spacing: 2px;
}

/* Overview Card */
.overview-card {
  padding: 20px;
  border: 1px solid #e5e7eb;
}

.overview-text {
  font-size: 14px;
  color: #374151;
  line-height: 1.8;
}

/* Data Grid */
.data-grid {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20px 0;
}

.data-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.data-val {
  font-size: 22px;
  font-weight: bold;
  color: #000;
  margin-bottom: 6px;
}

.data-lbl {
  font-size: 11px;
  color: #9ca3af;
}

.data-divider {
  width: 1px;
  height: 40px;
  background-color: #f3f4f6;
}

/* Chain */
.chain-container {
  display: flex;
  align-items: flex-start;
  gap: 8px;
  overflow-x: auto;
}

.chain-node {
  flex: 1;
  min-width: 0;
}

.chain-title {
  font-size: 12px;
  font-weight: bold;
  color: #000;
  display: block;
  margin-bottom: 8px;
  text-align: center;
}

.chain-tags {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.chain-tag {
  font-size: 11px;
  color: #6b7280;
  padding: 6px 8px;
  border: 1px solid #e5e7eb;
  border-radius: 4px;
  text-align: center;
  display: block;
}

.chain-tag.highlight {
  background-color: #000;
  color: #fff;
  border-color: #000;
  font-weight: 600;
}

.chain-arrow {
  font-size: 20px;
  color: #d1d5db;
  margin-top: 28px;
  flex-shrink: 0;
}

/* Players */
.player-list {
  border-top: 1px solid #000;
}

.player-item {
  display: flex;
  align-items: center;
  padding: 16px 0;
  border-bottom: 1px solid #f3f4f6;
  gap: 16px;
}

.player-rank {
  font-size: 12px;
  color: #9ca3af;
  font-family: ui-monospace, monospace;
  width: 24px;
  flex-shrink: 0;
}

.player-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.player-name {
  font-size: 15px;
  font-weight: 600;
  color: #000;
  margin-bottom: 2px;
}

.player-desc {
  font-size: 12px;
  color: #9ca3af;
}

.player-arrow {
  font-size: 22px;
  color: #d1d5db;
}

/* Bottom Action */
.bottom-action {
  margin: 24px;
  padding: 18px;
  background-color: #000;
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 8px;
}

.action-text {
  font-size: 15px;
  color: #fff;
  font-weight: 600;
}

.action-arrow {
  font-size: 16px;
  color: #fff;
}

.bottom-action:active {
  opacity: 0.8;
}
