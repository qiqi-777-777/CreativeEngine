<view class="container font-serif">
  <!-- 状态栏占位 -->
  <view class="status-bar" style="height: {{statusBarHeight}}px;"></view>

  <!-- 顶部导航 -->
  <view class="page-header">
    <text class="page-subtitle font-sans">INDUSTRY ATLAS</text>
    <view class="title-row">
      <view class="back-btn" bindtap="goBack">
        <text class="icon-back">←</text>
      </view>
      <text class="page-title">行业图谱</text>
    </view>
  </view>

  <!-- 行业分类选择 -->
  <scroll-view scroll-x class="category-scroll no-scrollbar font-sans">
    <view class="category-row">
      <view
        wx:for="{{industries}}"
        wx:key="id"
        class="category-tag {{activeIndustry === index ? 'active' : ''}}"
        bindtap="onIndustryTap"
        data-index="{{index}}"
      >
        <text>{{item.name}}</text>
      </view>
    </view>
  </scroll-view>

  <!-- 内容区域 -->
  <scroll-view scroll-y class="content-scroll no-scrollbar">
    <!-- 行业概述卡片 -->
    <view class="section-block">
      <view class="section-label-row">
        <text class="section-label">行业概述</text>
        <text class="section-en font-sans">Overview</text>
      </view>
      <view class="overview-card">
        <text class="overview-text font-sans">{{activeIndustryData.overview}}</text>
      </view>
    </view>

    <!-- 核心数据 -->
    <view class="section-block">
      <view class="section-label-row">
        <text class="section-label">核心数据</text>
        <text class="section-en font-sans">Key Data</text>
      </view>
      <view class="data-grid font-sans">
        <view class="data-item">
          <text class="data-val">{{activeIndustryData.marketSize}}</text>
          <text class="data-lbl">市场规模</text>
        </view>
        <view class="data-divider"></view>
        <view class="data-item">
          <text class="data-val">{{activeIndustryData.growth}}</text>
          <text class="data-lbl">年复合增长率</text>
        </view>
        <view class="data-divider"></view>
        <view class="data-item">
          <text class="data-val">{{activeIndustryData.heat}}</text>
          <text class="data-lbl">行业景气度</text>
        </view>
      </view>
    </view>

    <!-- 产业链上下游 -->
    <view class="section-block">
      <view class="section-label-row">
        <text class="section-label">产业链结构</text>
        <text class="section-en font-sans">Supply Chain</text>
      </view>
      <view class="chain-container font-sans">
        <view class="chain-node">
          <text class="chain-title">上游</text>
          <view class="chain-tags">
            <text class="chain-tag" wx:for="{{activeIndustryData.upstream}}" wx:key="*this">{{item}}</text>
          </view>
        </view>
        <view class="chain-arrow">→</view>
        <view class="chain-node chain-node-center">
          <text class="chain-title">核心</text>
          <view class="chain-tags">
            <text class="chain-tag highlight" wx:for="{{activeIndustryData.core}}" wx:key="*this">{{item}}</text>
          </view>
        </view>
        <view class="chain-arrow">→</view>
        <view class="chain-node">
          <text class="chain-title">下游</text>
          <view class="chain-tags">
            <text class="chain-tag" wx:for="{{activeIndustryData.downstream}}" wx:key="*this">{{item}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 主要玩家 -->
    <view class="section-block">
      <view class="section-label-row">
        <text class="section-label">竞争格局</text>
        <text class="section-en font-sans">Competition</text>
      </view>
      <view class="competition-insights font-sans">
        <view class="insight-card">
          <text class="insight-label">格局判断</text>
          <text class="insight-text">{{competition.concentration}}</text>
        </view>
        <view class="insight-card">
          <text class="insight-label">进入壁垒</text>
          <text class="insight-text">{{competition.barrier}}</text>
        </view>
        <view class="insight-card wide">
          <text class="insight-label">创业切入点</text>
          <text class="insight-text">{{competition.opportunity}}</text>
        </view>
      </view>
      <view class="player-list font-sans">
        <view class="player-item" wx:for="{{competition.players}}" wx:key="name">
          <view class="player-rank">{{index < 9 ? '0' : ''}}{{index + 1}}</view>
          <view class="player-info">
            <view class="player-name-row">
              <text class="player-name">{{item.name}}</text>
              <text class="player-role">{{item.role}}</text>
            </view>
            <text class="player-desc">{{item.desc}}</text>
            <view class="player-meta">
              <text>重点：{{item.focus}}</text>
              <text>启发：{{item.chance}}</text>
            </view>
          </view>
          <text class="player-arrow">›</text>
        </view>
      </view>
    </view>

    <!-- 底部按钮 -->
    <view class="bottom-action" bindtap="goToImageInterpretation">
      <text class="action-text">查看 AI 深度解读</text>
      <text class="action-arrow">→</text>
    </view>

    <view style="height: 60px;"></view>
  </scroll-view>
</view>
