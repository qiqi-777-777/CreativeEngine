/* pages/policy/policy.wxss */
page {
  background-color: #f0f3f8;
  height: 100vh;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, Segoe UI, Arial, Roboto, 'PingFang SC', 'miui', 'Hiragino Sans GB', 'Microsoft Yahei', sans-serif;
  color: #5a6a85;
}

.container {
  display: flex;
  flex-direction: column;
  height: 100%;
}

/* Animations */
@keyframes slideUpFade {
  0% { opacity: 0; transform: translateY(40px); }
  100% { opacity: 1; transform: translateY(0); }
}

.animate-slide-up-fade {
  animation: slideUpFade 0.7s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  opacity: 0;
}

/* Header Section */
.header-section {
  padding: 48rpx 56rpx 32rpx;
  flex-shrink: 0;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.title-wrapper {
  display: flex;
  flex-direction: column;
}

.page-title {
  font-size: 68rpx;
  font-weight: 900;
  color: #5a6a85;
  letter-spacing: -0.02em;
  margin-bottom: 8rpx;
}

.page-subtitle {
  font-size: 28rpx;
  color: #7a8b9e;
  font-weight: 500;
}

/* Filter Button */
.clay-btn-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 28rpx;
  background-color: #f0f3f8;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 6px 6px 12px #d9dfe9, -6px -6px 12px #ffffff;
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.clay-btn-icon:active {
  transform: scale(0.9);
  box-shadow: inset 4px 4px 8px #d9dfe9, inset -4px -4px 8px #ffffff;
}

.icon-sliders {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  width: 40rpx;
}

.slider-line {
  height: 4rpx;
  background-color: #7a8b9e;
  border-radius: 2rpx;
  position: relative;
  width: 100%;
}

.slider-knob {
  width: 12rpx;
  height: 12rpx;
  background-color: #f0f3f8;
  border: 4rpx solid #7a8b9e;
  border-radius: 50%;
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  left: 0;
  box-sizing: border-box;
}

.slider-line.reverse .slider-knob {
  left: auto;
  right: 0;
}

/* Search Section */
.search-section {
  padding: 0 56rpx 48rpx;
  flex-shrink: 0;
}

.clay-box {
  background-color: #f0f3f8;
  border-radius: 32rpx;
  box-shadow: inset 4px 4px 8px #d9dfe9, inset -4px -4px 8px #ffffff;
  padding: 20rpx 24rpx;
  display: flex;
  align-items: center;
}

.search-icon {
  margin-right: 20rpx;
  margin-left: 12rpx;
}

.search-input {
  flex: 1;
  font-size: 30rpx;
  color: #5a6a85;
}

.placeholder-style {
  color: #7a8b9e;
}

.match-btn {
  font-size: 24rpx;
  font-weight: bold;
  color: #7a8b9e;
  text-transform: uppercase;
  background-color: #f0f3f8;
  padding: 16rpx 32rpx;
  margin-left: 20rpx;
  border-radius: 20rpx;
  box-shadow: 4px 4px 8px #d9dfe9, -4px -4px 8px #ffffff, inset -2px -2px 4px rgba(0,0,0,0.02), inset 2px 2px 4px #ffffff;
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.match-btn:active {
  transform: scale(0.95);
  box-shadow: inset 4px 4px 8px #d9dfe9, inset -4px -4px 8px #ffffff;
}

/* List Content */
.policy-list {
  flex: 1;
  overflow: hidden;
}

.list-wrapper {
  padding: 0 56rpx;
  display: flex;
  flex-direction: column;
  gap: 40rpx;
}

.clay-card {
  background-color: #f0f3f8;
  border-radius: 48rpx;
  padding: 48rpx 40rpx;
  box-shadow: 12px 12px 24px #d9dfe9, -12px -12px 24px #ffffff;
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.clay-card:active {
  transform: scale(0.98);
  box-shadow: 6px 6px 12px #d9dfe9, -6px -6px 12px #ffffff;
}

.article-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 24rpx;
  gap: 20rpx;
}

.article-title {
  font-size: 34rpx;
  font-weight: 900;
  color: #5a6a85;
  line-height: 1.5;
  flex: 1;
}

.article-date {
  font-size: 22rpx;
  color: #7a8b9e;
  background-color: rgba(255,255,255,0.5);
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  white-space: nowrap;
  font-weight: bold;
}

.article-snippet {
  font-size: 28rpx;
  color: #7a8b9e;
  line-height: 1.6;
  margin-bottom: 40rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.article-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.article-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  flex: 1;
  padding-right: 20rpx;
}

.clay-tag {
  padding: 10rpx 24rpx;
  background-color: #f0f3f8;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: bold;
  color: #7a8b9e;
  box-shadow: 4px 4px 8px #d9dfe9, -4px -4px 8px #ffffff, inset -2px -2px 4px rgba(0,0,0,0.02), inset 2px 2px 4px #ffffff;
}

.clay-btn-small {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 28rpx;
  background-color: #f0f3f8;
  border-radius: 24rpx;
  box-shadow: 4px 4px 8px #d9dfe9, -4px -4px 8px #ffffff;
  color: #5a6a85;
  font-weight: bold;
  font-size: 24rpx;
  transition: all 0.3s;
}

.clay-btn-small:active {
  box-shadow: inset 4px 4px 8px #d9dfe9, inset -4px -4px 8px #ffffff;
  transform: scale(0.95);
}

.empty-state {
  display: flex;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: #7a8b9e;
  font-weight: bold;
  letter-spacing: 0.05em;
}

.bottom-spacer {
  height: 160rpx;
}
