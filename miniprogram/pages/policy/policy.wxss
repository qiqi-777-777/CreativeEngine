/* pages/policy/policy.wxss */
page {
  background-color: #FFFFFF;
  height: 100vh;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, Segoe UI, Arial, Roboto, 'PingFang SC', 'miui', 'Hiragino Sans GB', 'Microsoft Yahei', sans-serif;
}

.container {
  display: flex;
  flex-direction: column;
  height: 100%;
}

/* Header Section */
.header-section {
  padding: 48rpx 56rpx 24rpx;
  border-bottom: 4rpx solid #000000;
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  flex-shrink: 0;
}

.title-wrapper {
  display: flex;
  flex-direction: column;
}

.page-subtitle {
  font-size: 20rpx;
  letter-spacing: 0.3em;
  color: #9CA3AF;
  font-weight: bold;
  text-transform: uppercase;
  margin-bottom: 16rpx;
}

.page-title {
  font-size: 68rpx;
  font-family: Georgia, 'Times New Roman', Times, serif;
  font-weight: bold;
  color: #000000;
  line-height: 1;
  letter-spacing: -0.02em;
}

/* Sliders icon styling */
.filter-btn {
  width: 80rpx;
  height: 80rpx;
  border: 2rpx solid #000000;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
}

.filter-btn:active {
  background-color: #000000;
}

.filter-btn:active .slider-line,
.filter-btn:active .slider-knob {
  background-color: #FFFFFF;
  border-color: #FFFFFF;
}

.icon-sliders {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  width: 36rpx;
}

.slider-line {
  height: 2rpx;
  background-color: #000000;
  position: relative;
  width: 100%;
}

.slider-knob {
  width: 10rpx;
  height: 10rpx;
  border: 2rpx solid #000000;
  background-color: #FFFFFF;
  border-radius: 50%;
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  left: 4rpx;
}

.slider-line.reverse .slider-knob {
  left: auto;
  right: 4rpx;
}

/* Search Section */
.search-section {
  padding: 48rpx 56rpx;
  flex-shrink: 0;
}

.search-box {
  display: flex;
  align-items: center;
  border-bottom: 2rpx solid #D1D5DB;
  padding-bottom: 24rpx;
  transition: border-color 0.3s;
}

.search-box:focus-within {
  border-bottom-color: #000000;
}

.search-icon {
  margin-right: 24rpx;
  transition: color 0.3s;
}

.search-box:focus-within .search-icon {
  color: #000000 !important;
}

.search-input {
  flex: 1;
  font-size: 30rpx;
  color: #000000;
}

.placeholder-style {
  color: #9CA3AF;
}

.match-btn {
  font-size: 24rpx;
  font-weight: bold;
  color: #000000;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  background-color: #F3F4F6;
  padding: 12rpx 32rpx;
  margin-left: 16rpx;
  transition: all 0.2s;
}

.match-btn:active {
  background-color: #000000;
  color: #FFFFFF;
}

/* List Content */
.policy-list {
  flex: 1;
  overflow: hidden;
}

.list-wrapper {
  padding: 0 56rpx;
}

.policy-article {
  border-bottom: 2rpx solid #E5E7EB;
  padding: 64rpx 0;
  transition: border-color 0.3s;
}

.policy-article:active {
  opacity: 0.8;
}

.article-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.article-index {
  font-size: 20rpx;
  font-family: Georgia, 'Times New Roman', Times, serif;
  color: #9CA3AF;
  font-style: italic;
}

.article-date {
  font-size: 20rpx;
  letter-spacing: 0.1em;
  color: #9CA3AF;
  text-transform: uppercase;
}

.article-title {
  font-size: 38rpx;
  font-family: Georgia, 'Times New Roman', Times, serif;
  font-weight: bold;
  color: #000000;
  line-height: 1.4;
  margin-bottom: 24rpx;
}

.policy-article:hover .article-title {
  text-decoration: underline;
  text-decoration-thickness: 2rpx;
  text-underline-offset: 8rpx;
}

.article-snippet {
  font-size: 26rpx;
  color: #6B7280;
  line-height: 1.6;
  margin-bottom: 48rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.article-footer {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
}

.article-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  flex: 1;
  padding-right: 32rpx;
}

.tag {
  padding: 8rpx 16rpx;
  border: 2rpx solid #E5E7EB;
  font-size: 20rpx;
  color: #4B5563;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.article-action {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 22rpx;
  font-weight: bold;
  color: #000000;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  white-space: nowrap;
}

.arrow-right {
  font-size: 28rpx;
  font-weight: normal;
  margin-bottom: 4rpx;
}

.empty-state {
  display: flex;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-text {
  font-size: 24rpx;
  color: #9CA3AF;
  letter-spacing: 0.05em;
  text-transform: uppercase;
}

.bottom-spacer {
  height: 160rpx;
}
