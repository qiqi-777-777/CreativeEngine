<!--pages/index/index.wxml-->
<view class="container font-serif">
  <!-- Header -->
  <view class="header-section">
    <text class="header-subtitle font-sans">INNOVATION ENGINE</text>
    <view class="header-title-box">
      <text class="header-greeting">{{greeting}},</text>
      <text class="header-name">青年创享者.</text>
    </view>

    <view class="search-bar">
      <view class="search-icon"></view>
      <input type="text" placeholder="Search resources..." class="search-input font-sans" placeholder-class="search-placeholder" />
    </view>
  </view>

  <!-- Content Area -->
  <scroll-view scroll-y class="main-content">
    <!-- 原有轮播图区域 -->
    <view class="banner-section">
      <swiper class="banner-swiper"
              wx:if="{{bannerList && bannerList.length > 0}}"
              indicator-dots="{{true}}"
              indicator-color="rgba(255,255,255,0.4)"
              indicator-active-color="#ffffff"
              autoplay="{{true}}"
              interval="{{4000}}"
              duration="{{500}}"
              circular="{{true}}">
        <swiper-item wx:for="{{bannerList}}" wx:key="id" class="banner-item">
          <view class="banner-image-wrapper">
            <image class="banner-image" src="{{item.imageUrl}}" mode="aspectFill" />
            <view class="banner-overlay" wx:if="{{item.title}}">
              <text class="banner-title">{{item.title}}</text>
            </view>
          </view>
        </swiper-item>
      </swiper>
    </view>

    <!-- Core Services Header -->
    <view class="section-header">
      <text class="section-title">核心服务</text>
      <text class="section-subtitle font-sans">CORE SERVICES</text>
    </view>

    <!-- Core Services List -->
    <view class="service-list font-sans">
      <view class="service-item group" bindtap="goToCareerMatch">
        <view class="service-left">
          <text class="service-num font-mono">01</text>
          <view class="service-info">
            <text class="service-name">职业匹配</text>
            <text class="service-desc">精准定位方向</text>
          </view>
        </view>
        <view class="service-right">
           <text class="icon-chevron">›</text>
        </view>
      </view>

      <view class="service-item group" bindtap="goToPolicy">
        <view class="service-left">
          <text class="service-num font-mono">02</text>
          <view class="service-info">
            <text class="service-name">政策匹配</text>
            <text class="service-desc">获取扶持资金</text>
          </view>
        </view>
        <view class="service-right">
           <text class="icon-chevron">›</text>
        </view>
      </view>

      <view class="service-item group" bindtap="goToImageInterpretation">
        <view class="service-left">
          <text class="service-num font-mono">03</text>
          <view class="service-info">
            <text class="service-name">图说解读</text>
            <text class="service-desc">AI 智能读图</text>
          </view>
        </view>
        <view class="service-right">
           <text class="icon-chevron">›</text>
        </view>
      </view>

      <view class="service-item group border-none" bindtap="goToResource">
        <view class="service-left">
          <text class="service-num font-mono">04</text>
          <view class="service-info">
            <text class="service-name">资源对接</text>
            <text class="service-desc">找专家找场地</text>
          </view>
        </view>
        <view class="service-right">
           <text class="icon-chevron">›</text>
        </view>
      </view>
    </view>

    <view class="footer-spacer"></view>
  </scroll-view>
</view>
