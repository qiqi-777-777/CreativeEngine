/* expert-connect.wxss */
page { background-color: #ffffff; height: 100vh; overflow: hidden; }
view, scroll-view, text, image { box-sizing: border-box; }
.font-serif { font-family: "Georgia", "Times New Roman", serif, 'PingFang SC', 'Microsoft YaHei'; }
.font-sans { font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, 'PingFang SC', 'Microsoft YaHei', sans-serif; }
.container { display: flex; flex-direction: column; height: 100vh; background: #fff; }
.status-bar { width: 100%; flex-shrink: 0; }
.no-scrollbar::-webkit-scrollbar { display: none; }

/* Header */
.page-header { padding: 8px 24px 16px; flex-shrink: 0; }
.page-subtitle { font-size: 10px; letter-spacing: 3px; color: #9ca3af; text-transform: uppercase; display: block; margin-bottom: 4px; }
.title-row { display: flex; align-items: center; gap: 12px; }
.back-btn { width: 36px; height: 36px; border-radius: 50%; border: 1px solid #e5e7eb; display: flex; align-items: center; justify-content: center; }
.back-btn:active { background-color: #000; border-color: #000; }
.back-btn:active .icon-back { color: #fff; }
.icon-back { font-size: 18px; color: #000; }
.page-title { font-size: 28px; font-weight: bold; color: #000; }

/* Category */
.category-scroll { padding: 0 24px 16px; flex-shrink: 0; white-space: nowrap; border-bottom: 1px solid #000; }
.category-row { display: inline-flex; gap: 10px; }
.category-tag { display: inline-flex; padding: 8px 20px; border: 1px solid #e5e7eb; border-radius: 999px; font-size: 13px; color: #6b7280; white-space: nowrap; transition: all 0.3s; }
.category-tag.active { background-color: #000; border-color: #000; color: #fff; }

/* Content */
.content-scroll { flex: 1; height: 0; padding: 0 24px; }

.expert-count { padding: 16px 0; font-size: 12px; color: #9ca3af; }

/* Expert Card */
.expert-card {
  padding: 24px 0;
  border-bottom: 1px solid #f3f4f6;
}
.expert-card:active { padding-left: 8px; }

.expert-header { display: flex; align-items: center; gap: 16px; margin-bottom: 12px; }
.expert-avatar {
  width: 56px; height: 56px; border-radius: 50%;
  border: 1px solid #000; display: flex; align-items: center; justify-content: center;
  background: #fff; flex-shrink: 0;
}
.avatar-char { font-size: 22px; font-weight: bold; color: #000; }
.expert-info { flex: 1; }
.expert-name-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 4px; }
.expert-name { font-size: 18px; font-weight: 700; color: #000; }
.expert-rating { font-size: 13px; color: #000; font-weight: 600; }
.expert-title { font-size: 13px; color: #9ca3af; }

.expert-tags { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 12px; }
.expert-tag { font-size: 11px; padding: 4px 12px; border: 1px solid #e5e7eb; border-radius: 999px; color: #374151; }

.expert-footer { display: flex; justify-content: space-between; align-items: center; }
.expert-consult { font-size: 12px; color: #d1d5db; }
.expert-arrow { font-size: 22px; color: #d1d5db; }

.empty-hint { padding: 60px; text-align: center; color: #d1d5db; font-size: 14px; }

/* Modal */
.modal-overlay {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.4); z-index: 100;
}
.modal-panel {
  position: fixed; left: 0; right: 0; bottom: 0;
  background: #fff; border-radius: 24px 24px 0 0;
  max-height: 75vh; z-index: 101;
  transform: translateY(100%);
  transition: transform 0.3s ease;
}
.modal-panel.show { transform: translateY(0); }

.modal-handle-wrap { display: flex; justify-content: center; align-items: center; padding: 12px 20px 0; position: relative; }
.modal-handle { width: 40px; height: 4px; border-radius: 2px; background: #e5e7eb; }
.modal-close { position: absolute; right: 20px; top: 12px; font-size: 18px; color: #9ca3af; padding: 4px 8px; }

.modal-scroll { padding: 20px 24px 40px; max-height: calc(75vh - 40px); }

/* Detail */
.detail-header { display: flex; align-items: center; gap: 16px; margin-bottom: 24px; padding-bottom: 24px; border-bottom: 1px solid #f3f4f6; }
.detail-avatar { width: 64px; height: 64px; border-radius: 50%; border: 1px solid #000; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.detail-avatar-char { font-size: 26px; font-weight: bold; color: #000; }
.detail-info { flex: 1; }
.detail-name { font-size: 22px; font-weight: bold; color: #000; display: block; margin-bottom: 4px; }
.detail-title { font-size: 13px; color: #6b7280; display: block; margin-bottom: 4px; }
.detail-rating { font-size: 12px; color: #9ca3af; }

.detail-section { margin-bottom: 24px; }
.detail-label { font-size: 16px; font-weight: bold; color: #000; display: block; margin-bottom: 12px; }
.detail-text { font-size: 14px; color: #6b7280; line-height: 1.8; }
.detail-tags { display: flex; flex-wrap: wrap; gap: 8px; }
.detail-tag { font-size: 12px; padding: 6px 14px; border: 1px solid #000; border-radius: 999px; color: #000; }

.service-info-grid { display: flex; gap: 16px; }
.service-info-item { flex: 1; text-align: center; padding: 16px 0; border: 1px solid #e5e7eb; }
.service-info-val { font-size: 16px; font-weight: bold; color: #000; display: block; margin-bottom: 4px; }
.service-info-lbl { font-size: 11px; color: #9ca3af; }

.book-btn {
  width: 100%; padding: 18px; background: #000; text-align: center;
  color: #fff; font-size: 16px; font-weight: 600; margin-top: 8px;
}
.book-btn:active { opacity: 0.8; }
