/* pages/user-agreement/user-agreement.wxss */
.container {
  padding: 40rpx;
  background: #f0f3f8;
  min-height: 100vh;
}

.content {
  background: #f0f3f8;
  border-radius: 48rpx;
  padding: 40rpx;
  box-shadow: 12px 12px 24px #d9dfe9, -12px -12px 24px #ffffff;
  animation: slideUpFade 0.7s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #5a6a85;
  text-align: center;
  margin-bottom: 40rpx;
}

.section {
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #5a6a85;
  margin-bottom: 16rpx;
}

.section-content {
  font-size: 26rpx;
  color: #7a8b9e;
  line-height: 1.6;
}

@keyframes slideUpFade {
  0% { opacity: 0; transform: translateY(40px); }
  100% { opacity: 1; transform: translateY(0); }
}
