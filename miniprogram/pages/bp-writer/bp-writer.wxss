/* bp-writer.wxss */
page { background-color: #ffffff; height: 100vh; overflow: hidden; }
.font-serif { font-family: "Georgia", "Times New Roman", serif, 'PingFang SC', 'Microsoft YaHei'; }
.font-sans { font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, 'PingFang SC', 'Microsoft YaHei', sans-serif; }
.container { display: flex; flex-direction: column; height: 100vh; background: #fff; }
.status-bar { width: 100%; flex-shrink: 0; }
.no-scrollbar::-webkit-scrollbar { display: none; }

/* Header */
.page-header { padding: 8px 24px 16px; flex-shrink: 0; }
.page-subtitle { font-size: 10px; letter-spacing: 3px; color: #9ca3af; text-transform: uppercase; display: block; margin-bottom: 4px; }
.title-row { display: flex; align-items: center; gap: 12px; }
.back-btn { width: 36px; height: 36px; border-radius: 50%; border: 1px solid #e5e7eb; display: flex; align-items: center; justify-content: center; }
.back-btn:active { background-color: #000; border-color: #000; }
.back-btn:active .icon-back { color: #fff; }
.icon-back { font-size: 18px; color: #000; }
.page-title { font-size: 28px; font-weight: bold; color: #000; }

/* Content */
.content-scroll { flex: 1; height: 0; }

/* Step Indicator */
.step-indicator {
  padding: 24px 24px 0;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.step-dots {
  display: flex;
  align-items: center;
  gap: 0;
}
.step-dot {
  width: 10px;
  height: 10px;
  border-radius: 50%;
  background-color: #e5e7eb;
  transition: all 0.3s;
}
.step-dot.active {
  background-color: #000;
}
.step-line {
  width: 40px;
  height: 2px;
  background-color: #e5e7eb;
  transition: all 0.3s;
}
.step-line.active {
  background-color: #000;
}
.step-hint {
  font-size: 12px;
  color: #9ca3af;
  letter-spacing: 1px;
}

.autosave-hint {
  display: block;
  padding: 8px 24px 0;
  font-size: 11px;
  color: #9ca3af;
}

/* Form */
.form-section {
  padding: 32px 24px;
}
.form-label-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: 16px;
}
.form-label {
  font-size: 20px;
  font-weight: bold;
  color: #000;
}
.form-en {
  font-size: 10px;
  color: #9ca3af;
  text-transform: uppercase;
  letter-spacing: 2px;
}
.form-input {
  width: 100%;
  height: 44px;
  border: none;
  border-bottom: 1px solid #000;
  padding: 0;
  font-size: 16px;
  color: #000;
  box-sizing: border-box;
}
.form-textarea {
  width: 100%;
  border: 1px solid #e5e7eb;
  padding: 16px;
  font-size: 14px;
  color: #000;
  min-height: 100px;
  line-height: 1.8;
  box-sizing: border-box;
}
.form-textarea.tall {
  min-height: 160px;
}

/* Form Navigation */
.form-nav {
  display: flex;
  justify-content: space-between;
  padding: 8px 24px 24px;
  gap: 16px;
}
.nav-btn {
  flex: 1;
  padding: 16px;
  text-align: center;
  font-size: 15px;
  font-weight: 600;
  transition: all 0.3s;
}
.nav-prev {
  border: 1px solid #e5e7eb;
  color: #6b7280;
}
.nav-prev.disabled {
  opacity: 0.3;
  pointer-events: none;
}
.nav-prev:active {
  background-color: #f9fafb;
}
.nav-next {
  background-color: #000;
  color: #fff;
}
.nav-next:active { opacity: 0.8; }
.nav-generate {
  background-color: #000;
  color: #fff;
}
.nav-generate:active { opacity: 0.8; }

/* Result Section */
.result-section {
  padding: 0 24px;
}
.result-header-bar {
  padding: 24px 0;
  border-bottom: 1px solid #000;
  margin-bottom: 24px;
}
.result-main-title {
  font-size: 24px;
  font-weight: bold;
  color: #000;
  display: block;
  margin-bottom: 4px;
}
.result-sub {
  font-size: 10px;
  color: #9ca3af;
  letter-spacing: 2px;
}

.result-save-hint {
  display: block;
  margin-top: 8px;
  font-size: 11px;
  color: #9ca3af;
  letter-spacing: 0;
}

/* Loading */
.loading-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60px 0;
}
.loading-dot-group {
  display: flex;
  gap: 8px;
  margin-bottom: 16px;
}
.loading-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background-color: #000;
  animation: blink 1.4s infinite both;
}
.loading-dot:nth-child(2) { animation-delay: 0.2s; }
.loading-dot:nth-child(3) { animation-delay: 0.4s; }
@keyframes blink {
  0%, 80%, 100% { opacity: 0.2; }
  40% { opacity: 1; }
}
.loading-text {
  font-size: 14px;
  color: #9ca3af;
}

/* BP Content */
.bp-content {
  padding: 0 0 24px;
}
.bp-text {
  font-size: 14px;
  color: #374151;
  line-height: 2;
  white-space: pre-wrap;
}

/* Result Actions */
.result-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 16px;
  padding-bottom: 24px;
}
.action-btn-outline {
  flex: 1 1 calc(50% - 8px);
  padding: 16px;
  text-align: center;
  border: 1px solid #000;
  font-size: 15px;
  font-weight: 600;
  color: #000;
  box-sizing: border-box;
}
.action-btn-outline:active { background-color: #f9fafb; }
.action-btn-solid {
  flex: 1 1 100%;
  padding: 16px;
  text-align: center;
  background-color: #000;
  font-size: 15px;
  font-weight: 600;
  color: #fff;
  box-sizing: border-box;
}
.action-btn-solid:active { opacity: 0.8; }

/* ================= Clay Theme Overrides ================= */
page,
.container {
  background-color: #f0f3f8;
  color: #5a6a85;
}

.page-header,
.step-indicator,
.form-section,
.result-section {
  animation: slideUpFade 0.7s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}

.page-subtitle,
.step-hint,
.autosave-hint,
.form-en,
.result-sub,
.result-save-hint,
.loading-text,
.bp-text {
  color: #7a8b9e;
}

.page-title,
.form-label,
.result-main-title {
  color: #5a6a85;
}

.back-btn,
.form-input,
.form-textarea,
.nav-btn,
.action-btn-outline,
.action-btn-solid {
  border: none;
  border-radius: 18px;
  background-color: #f0f3f8;
  box-shadow: 6px 6px 12px #d9dfe9, -6px -6px 12px #ffffff;
}

.back-btn:active,
.nav-btn:active,
.action-btn-outline:active,
.action-btn-solid:active {
  opacity: 1;
  transform: scale(0.95);
  box-shadow: inset 4px 4px 8px #d9dfe9, inset -4px -4px 8px #ffffff;
}

.back-btn:active .icon-back {
  color: #7a8b9e;
}

.icon-back {
  color: #7a8b9e;
}

.step-dot.active,
.step-line.active,
.loading-dot {
  background-color: #ff9a9e;
}

.step-dot,
.step-line {
  background-color: #d9dfe9;
}

.form-input,
.form-textarea {
  color: #5a6a85;
  box-shadow: inset 4px 4px 8px #d9dfe9, inset -4px -4px 8px #ffffff;
}

.nav-next,
.nav-generate,
.action-btn-solid {
  background-color: #a1c4fd;
  color: #ffffff;
  box-shadow: 8px 8px 20px #c2d8ff, -8px -8px 20px #ffffff;
}

.nav-prev,
.action-btn-outline {
  color: #7a8b9e;
}

.result-header-bar {
  border-bottom: none;
  padding: 24px;
  border-radius: 24px;
  background-color: #f0f3f8;
  box-shadow: 12px 12px 24px #d9dfe9, -12px -12px 24px #ffffff;
}

@keyframes slideUpFade {
  0% { opacity: 0; transform: translateY(40px); }
  100% { opacity: 1; transform: translateY(0); }
}
