/* 基础字体与全局样式 */
page {
  background-color: #f0f3f8;
  height: 100vh;
  overflow: hidden;
}

view, scroll-view, text {
  box-sizing: border-box;
}

.font-serif {
  font-family: serif, 'Georgia', 'Times New Roman', 'PingFang SC', 'Microsoft YaHei', sans-serif;
}

.font-sans {
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, 'PingFang SC', 'Microsoft YaHei', sans-serif;
}

.container {
  width: 100%;
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f0f3f8;
  color: #5a6a85;
}

.status-bar {
  width: 100%;
}

.nav-bar {
  height: 44px;
  width: 100%;
}

/* Header / User Info */
.header-section {
  padding: 32px 24px 32px 24px;
  border-bottom: none;
  display: flex;
  align-items: center;
  flex-shrink: 0;
  gap: 24px;
  animation: slideUpFade 0.7s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}

.avatar-box {
  width: 84px;
  height: 84px;
  border-radius: 30px;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #f0f3f8;
  box-shadow: 12px 12px 24px #d9dfe9, -12px -12px 24px #ffffff;
  flex-shrink: 0;
  overflow: hidden;
  position: relative;
}

.avatar-changeable {
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.avatar-changeable:active {
  transform: scale(0.94);
  box-shadow: inset 5px 5px 10px #d9dfe9, inset -5px -5px 10px #ffffff;
}

.avatar-icon {
  width: 36px;
  height: 36px;
  background-color: #7a8b9e;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 已登录头像样式 */
.avatar-logged {
  background-color: #ff9a9e;
  box-shadow: inset 5px 5px 10px #e68b8e, inset -5px -5px 10px #ffabae;
}

.avatar-image {
  width: 100%;
  height: 100%;
  border-radius: 30px;
}

.avatar-edit-badge {
  position: absolute;
  left: 8px;
  right: 8px;
  bottom: 8px;
  height: 20px;
  border-radius: 999px;
  background-color: rgba(90, 106, 133, 0.72);
  color: #ffffff;
  font-size: 10px;
  line-height: 20px;
  text-align: center;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, sans-serif;
}

.avatar-letter {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-letter text {
  font-size: 32px;
  font-weight: 700;
  color: #ffffff;
  font-family: serif, 'Georgia', 'Times New Roman', sans-serif;
}

.user-info-box {
  display: flex;
  flex-direction: column;
}

.user-title {
  font-size: 26px;
  font-weight: bold;
  color: #5a6a85;
  margin-bottom: 12px;
  letter-spacing: 1px;
}

.user-subtitle {
  font-size: 10px;
  font-weight: bold;
  letter-spacing: 0.2em;
  color: #7a8b9e;
  text-transform: uppercase;
  border: none;
  border-radius: 9999px;
  padding: 6px 16px;
  align-self: flex-start;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, sans-serif;
  background-color: #f0f3f8;
  box-shadow: 4px 4px 8px #d9dfe9, -4px -4px 8px #ffffff;
}

.user-subtitle-active {
  background-color: #a1c4fd;
  color: #fff;
  box-shadow: inset 4px 4px 8px #91b0e4, inset -4px -4px 8px #b1d8ff;
}

.content-scroll {
  flex: 1;
  height: 0;
}

.no-scrollbar::-webkit-scrollbar {
  display: none;
}

/* Stats Section */
.stats-section {
  display: flex;
  gap: 12px;
  padding: 24px;
  border-bottom: none;
  animation: slideUpFade 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.1s forwards;
  opacity: 0;
}

.stat-item {
  flex: 1;
  min-height: 88px;
  border: none;
  border-radius: 24px;
  padding: 16px 10px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
  background-color: #f0f3f8;
  box-shadow: 8px 8px 16px #d9dfe9, -8px -8px 16px #ffffff;
}

.stat-item:active {
  transform: scale(0.96);
  box-shadow: inset 4px 4px 8px #d9dfe9, inset -4px -4px 8px #ffffff;
}

.stat-val {
  font-size: 28px;
  font-weight: bold;
  color: #5a6a85;
  line-height: 1;
}

.stat-lbl {
  font-size: 12px;
  color: #7a8b9e;
  font-weight: 700;
  margin-top: 8px;
}

.stat-desc {
  font-size: 10px;
  color: #9ca3af;
  margin-top: 4px;
}

/* Common Services */
.common-services {
  padding: 32px 24px;
  border-bottom: none;
  animation: slideUpFade 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.2s forwards;
  opacity: 0;
}

.services-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: 32px;
}

.services-title {
  font-size: 20px;
  font-weight: bold;
  color: #5a6a85;
}

.services-en {
  font-size: 10px;
  color: #7a8b9e;
  text-transform: uppercase;
  letter-spacing: 0.1em;
}

.services-grid {
  display: flex;
  justify-content: space-between;
  padding: 0 8px;
}

.service-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.service-icon {
  width: 56px;
  height: 56px;
  border-radius: 22px;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12px;
  transition: all 0.3s;
  background-color: #f0f3f8;
  box-shadow: 6px 6px 12px #d9dfe9, -6px -6px 12px #ffffff;
}

.service-icon-text {
  font-size: 22px;
  color: #7a8b9e;
}

.service-lbl {
  font-size: 12px;
  color: #5a6a85;
  font-weight: 500;
}

/* Interactions */
.service-item:active .service-icon {
  background-color: #ff9a9e;
  box-shadow: inset 4px 4px 8px #e68b8e, inset -4px -4px 8px #ffabae;
}

.service-item:active .service-icon-text {
  color: #fff;
}

/* List Items */
.menu-list {
  padding: 8px 24px 0 24px;
  animation: slideUpFade 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.3s forwards;
  opacity: 0;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18px 20px;
  margin-bottom: 16px;
  border-bottom: none;
  border-radius: 22px;
  background-color: #f0f3f8;
  box-shadow: 8px 8px 16px #d9dfe9, -8px -8px 16px #ffffff;
  transition: all 0.3s;
}

.menu-left {
  display: flex;
  align-items: center;
  gap: 16px;
}

.menu-icon-placeholder {
  width: 20px;
  height: 20px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.dot {
  width: 8px;
  height: 8px;
  background-color: #7a8b9e;
  border-radius: 50%;
  transition: all 0.3s;
}

.menu-label {
  font-size: 15px;
  color: #5a6a85;
  font-weight: 500;
}

.menu-right {
  display: flex;
  align-items: center;
  gap: 12px;
}

.menu-action {
  font-size: 10px;
  font-weight: bold;
  border: none;
  padding: 4px 12px;
  border-radius: 9999px;
  color: #ffffff;
  background-color: #ff9a9e;
}

.arrow {
  font-size: 16px;
  color: #7a8b9e;
  transition: all 0.3s;
}

.menu-item:active {
  transform: scale(0.98);
  box-shadow: inset 4px 4px 8px #d9dfe9, inset -4px -4px 8px #ffffff;
}

.menu-item:active .dot {
  background-color: #a1c4fd;
}

.menu-item:active .arrow {
  color: #000;
}

/* ================== Logout Button ================== */
.logout-section {
  padding: 32px 24px 0;
}

.logout-btn {
  width: 100%;
  height: 52px;
  border: none;
  border-radius: 24px;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s;
  background-color: #f0f3f8;
  box-shadow: 8px 8px 16px #d9dfe9, -8px -8px 16px #ffffff;
}

.logout-btn:active {
  background-color: #f0f3f8;
  transform: scale(0.97);
  box-shadow: inset 4px 4px 8px #d9dfe9, inset -4px -4px 8px #ffffff;
}

.logout-btn:active .logout-text {
  color: #fff;
}

.logout-text {
  font-size: 14px;
  color: #7a8b9e;
  font-weight: 500;
  letter-spacing: 2px;
  transition: color 0.3s;
}

@keyframes slideUpFade {
  0% { opacity: 0; transform: translateY(40px); }
  100% { opacity: 1; transform: translateY(0); }
}
