/* 基础字体与全局样式 */
page {
  background-color: #ffffff;
  height: 100vh;
  overflow: hidden;
}

view, scroll-view, text {
  box-sizing: border-box;
}

.font-serif {
  font-family: serif, 'Georgia', 'Times New Roman', 'PingFang SC', 'Microsoft YaHei', sans-serif;
}

.font-sans {
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, 'PingFang SC', 'Microsoft YaHei', sans-serif;
}

.container {
  width: 100%;
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #ffffff;
  color: #000000;
}

.status-bar {
  width: 100%;
}

.nav-bar {
  height: 44px;
  width: 100%;
}

/* Header / User Info */
.header-section {
  padding: 32px 24px 32px 24px;
  border-bottom: 1px solid #000;
  display: flex;
  align-items: center;
  flex-shrink: 0;
  gap: 24px;
}

.avatar-box {
  width: 84px;
  height: 84px;
  border-radius: 50%;
  border: 1px solid #000;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #ffffff;
  box-shadow: 8px 8px 0 rgba(0,0,0,0.05);
  flex-shrink: 0;
  overflow: hidden;
}

.avatar-icon {
  width: 36px;
  height: 36px;
  background-color: #e5e7eb;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 已登录头像样式 */
.avatar-logged {
  background-color: #000000;
}

.avatar-image {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.avatar-letter {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-letter text {
  font-size: 32px;
  font-weight: 700;
  color: #ffffff;
  font-family: serif, 'Georgia', 'Times New Roman', sans-serif;
}

.user-info-box {
  display: flex;
  flex-direction: column;
}

.user-title {
  font-size: 26px;
  font-weight: bold;
  color: #000000;
  margin-bottom: 12px;
  letter-spacing: 1px;
}

.user-subtitle {
  font-size: 10px;
  font-weight: bold;
  letter-spacing: 0.2em;
  color: #000;
  text-transform: uppercase;
  border: 1px solid #000;
  border-radius: 9999px;
  padding: 6px 16px;
  align-self: flex-start;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, sans-serif;
}

.user-subtitle-active {
  background-color: #000;
  color: #fff;
}

.content-scroll {
  flex: 1;
  height: 0;
}

.no-scrollbar::-webkit-scrollbar {
  display: none;
}

/* Stats Section */
.stats-section {
  display: flex;
  justify-content: space-between;
  padding: 32px 40px;
  border-bottom: 1px solid #f3f4f6;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-val {
  font-size: 28px;
  font-weight: bold;
  color: #000;
  line-height: 1;
}

.stat-lbl {
  font-size: 11px;
  color: #6b7280;
  font-weight: 500;
  margin-top: 8px;
}

.stat-divider {
  width: 1px;
  height: 40px;
  background-color: #f3f4f6;
  margin-top: 5px;
}

/* Common Services */
.common-services {
  padding: 32px 24px;
  border-bottom: 1px solid #000;
}

.services-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: 32px;
}

.services-title {
  font-size: 20px;
  font-weight: bold;
  color: #000;
}

.services-en {
  font-size: 10px;
  color: #9ca3af;
  text-transform: uppercase;
  letter-spacing: 0.1em;
}

.services-grid {
  display: flex;
  justify-content: space-between;
  padding: 0 8px;
}

.service-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.service-icon {
  width: 56px;
  height: 56px;
  border-radius: 50%;
  border: 1px solid #e5e7eb;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12px;
  transition: all 0.3s;
}

.service-icon-text {
  font-size: 22px;
  color: #000;
}

.service-lbl {
  font-size: 12px;
  color: #000;
  font-weight: 500;
}

/* Interactions */
.service-item:active .service-icon {
  background-color: #000;
  border-color: #000;
}

.service-item:active .service-icon-text {
  color: #fff;
}

/* List Items */
.menu-list {
  padding: 8px 24px 0 24px;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22px 0;
  border-bottom: 1px solid #f3f4f6;
  transition: all 0.3s;
}

.menu-left {
  display: flex;
  align-items: center;
  gap: 16px;
}

.menu-icon-placeholder {
  width: 20px;
  height: 20px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.dot {
  width: 8px;
  height: 8px;
  background-color: #9ca3af;
  border-radius: 50%;
  transition: all 0.3s;
}

.menu-label {
  font-size: 15px;
  color: #000;
  font-weight: 500;
}

.menu-right {
  display: flex;
  align-items: center;
  gap: 12px;
}

.menu-action {
  font-size: 10px;
  font-weight: bold;
  border: 1px solid #000;
  padding: 4px 12px;
  border-radius: 9999px;
  color: #000;
}

.arrow {
  font-size: 16px;
  color: #d1d5db;
  transition: all 0.3s;
}

.menu-item:active {
  padding-left: 8px;
}

.menu-item:active .dot {
  background-color: #000;
}

.menu-item:active .arrow {
  color: #000;
}

/* ================== Logout Button ================== */
.logout-section {
  padding: 32px 24px 0;
}

.logout-btn {
  width: 100%;
  height: 52px;
  border: 1px solid #e5e7eb;
  border-radius: 9999px;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s;
}

.logout-btn:active {
  background-color: #000;
  border-color: #000;
}

.logout-btn:active .logout-text {
  color: #fff;
}

.logout-text {
  font-size: 14px;
  color: #9ca3af;
  font-weight: 500;
  letter-spacing: 2px;
  transition: color 0.3s;
}
