<view class="container font-serif">
  <view class="status-bar" style="height: {{statusBarHeight}}px;"></view>
  <view class="nav-bar"></view>

  <!-- Header: 未登录状态 -->
  <view class="header-section" wx:if="{{!isLogin}}">
    <view class="avatar-box">
      <view class="avatar-icon"></view>
    </view>
    <view class="user-info-box">
      <view class="user-title" bindtap="handleLogin">点击登录 / 注册</view>
      <view class="user-subtitle">开启您的创业之旅</view>
    </view>
  </view>

  <!-- Header: 已登录状态 -->
  <view class="header-section" wx:else>
    <view class="avatar-box avatar-logged">
      <image
        wx:if="{{userInfo.avatar}}"
        class="avatar-image"
        src="{{userInfo.avatar}}"
        mode="aspectFill"
      ></image>
      <view wx:else class="avatar-letter">
        <text>{{avatarLetter}}</text>
      </view>
    </view>
    <view class="user-info-box">
      <view class="user-title">{{userInfo.nickname || userInfo.username}}</view>
      <view class="user-subtitle user-subtitle-active">创业之旅已开启</view>
    </view>
  </view>

  <scroll-view scroll-y class="content-scroll no-scrollbar">
    <view class="stats-section font-sans">
      <block wx:for="{{stats}}" wx:key="label">
        <view class="stat-item" bindtap="handleStatClick" data-index="{{index}}">
          <text class="stat-val">{{item.value}}</text>
          <text class="stat-lbl">{{item.label}}</text>
        </view>
        <view class="stat-divider" wx:if="{{index < stats.length - 1}}"></view>
      </block>
    </view>

    <view class="common-services">
      <view class="services-header">
        <text class="services-title">常用服务</text>
        <text class="services-en font-sans">Common</text>
      </view>

      <view class="services-grid font-sans">
        <block wx:for="{{services}}" wx:key="label">
          <view class="service-item" bindtap="handleServiceClick" data-item="{{item}}">
            <view class="service-icon">
              <text class="service-icon-text font-serif">{{item.iconChar}}</text>
            </view>
            <text class="service-lbl">{{item.label}}</text>
          </view>
        </block>
      </view>
    </view>

    <view class="menu-list font-sans">
      <block wx:for="{{menuItems}}" wx:key="label">
        <view class="menu-item" bindtap="handleMenuClick" data-item="{{item}}">
          <view class="menu-left">
            <view class="menu-icon-placeholder">
              <view class="dot"></view>
            </view>
            <text class="menu-label">{{item.label}}</text>
          </view>
          <view class="menu-right">
            <text class="menu-action" wx:if="{{item.text}}">{{item.text}}</text>
            <text class="arrow">></text>
          </view>
        </view>
      </block>
    </view>

    <!-- 退出登录按钮（仅登录后显示） -->
    <view class="logout-section" wx:if="{{isLogin}}">
      <view class="logout-btn" bindtap="handleLogout">
        <text class="logout-text font-sans">退出登录</text>
      </view>
    </view>

    <view style="height: 100px;"></view>
  </scroll-view>
</view>
