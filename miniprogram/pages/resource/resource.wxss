/* ================= List View ================= */
.header-area {
  padding: 48rpx 56rpx 16rpx 56rpx;
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  flex-shrink: 0;
}

.header-subtitle {
  font-size: 20rpx;
  letter-spacing: 0.3em;
  color: #9ca3af;
  font-weight: 700;
  text-transform: uppercase;
  margin-bottom: 16rpx;
}

.header-title {
  font-size: 68rpx;
  font-family: serif;
  font-weight: 700;
  color: #000000;
  line-height: 1;
  letter-spacing: -0.025em;
}

.search-btn {
  width: 80rpx;
  height: 80rpx;
  border: 2rpx solid #000000;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
}
.search-btn:active {
  background-color: #000000;
}
.search-btn:active .icon-search {
  filter: invert(1);
}

.tabs-area {
  padding: 48rpx 56rpx 16rpx 56rpx;
  border-bottom: 2rpx solid #000000;
  flex-shrink: 0;
}

.tabs-scroll {
  display: flex;
  white-space: nowrap;
  width: 100%;
}

.tab-item {
  position: relative;
  font-size: 26rpx;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: #9ca3af;
  margin-right: 48rpx;
  padding-bottom: 16rpx;
  transition: color 0.3s;
}

.tab-item.active {
  color: #000000;
}

.tab-indicator {
  position: absolute;
  bottom: -18rpx; /* aligns with border-bottom */
  left: 0;
  right: 0;
  height: 4rpx;
  background-color: #000000;
}

.list-area {
  flex: 1;
  width: 100%;
  height: 0;
}

.list-content {
  padding: 32rpx 56rpx 160rpx 56rpx;
  display: flex;
  flex-direction: column;
}

.resource-card {
  border-bottom: 2rpx solid #e5e7eb;
  padding: 64rpx 0;
  transition: border-color 0.2s;
}
.resource-card:active {
  opacity: 0.8;
}

.card-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.card-category {
  padding: 4rpx 16rpx;
  border: 2rpx solid #000000;
  font-size: 20rpx;
  font-weight: 700;
  color: #000000;
  letter-spacing: 0.1em;
}

.card-status {
  font-size: 18rpx;
  letter-spacing: 0.2em;
  font-weight: 700;
  text-transform: uppercase;
  color: #9ca3af;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.status-dot {
  width: 12rpx;
  height: 12rpx;
  background-color: #000000;
  border-radius: 50%;
}

.card-main {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 24rpx;
  gap: 32rpx;
}

.card-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #000000;
  line-height: 1.3;
}

.card-salary-box {
  text-align: right;
  flex-shrink: 0;
}

.salary-val {
  font-size: 44rpx;
  font-family: serif;
  font-weight: 700;
  color: #000000;
  line-height: 1;
}

.salary-unit {
  font-size: 20rpx;
  color: #6b7280;
  font-weight: 500;
  margin-left: 8rpx;
}

.card-desc {
  font-size: 26rpx;
  color: #6b7280;
  line-height: 1.6;
  margin-bottom: 40rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
}

.card-location {
  display: flex;
  align-items: center;
  color: #9ca3af;
  gap: 12rpx;
}

.card-location text {
  font-size: 22rpx;
  font-weight: 500;
}

.card-arrow {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  border: 2rpx solid #e5e7eb;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
}

/* ================= Detail View ================= */
.detail-nav {
  padding: 32rpx 40rpx 16rpx 40rpx;
  display: flex;
  align-items: center;
  flex-shrink: 0;
  position: relative;
  z-index: 40;
}

.back-btn {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: -16rpx;
}
.back-btn:active {
  background-color: #f3f4f6;
}

.detail-scroll {
  flex: 1;
  width: 100%;
  height: 0;
}

.detail-content {
  padding: 32rpx 56rpx 256rpx 56rpx;
}

.detail-header-box {
  border-bottom: 2rpx solid #000000;
  padding-bottom: 64rpx;
  margin-bottom: 64rpx;
}

.detail-en {
  font-size: 20rpx;
  letter-spacing: 0.2em;
  color: #9ca3af;
  font-weight: 700;
  text-transform: uppercase;
  margin-bottom: 16rpx;
}

.detail-title-large {
  font-size: 64rpx;
  font-weight: 700;
  color: #000000;
  line-height: 1.2;
  letter-spacing: -0.025em;
  margin-bottom: 48rpx;
}

.remuneration-box {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.rem-label {
  font-size: 22rpx;
  color: #6b7280;
  text-transform: uppercase;
  letter-spacing: 0.1em;
}

.rem-val-box {
  display: flex;
  align-items: baseline;
}

.rem-val {
  font-size: 72rpx;
  font-family: serif;
  font-weight: 700;
  color: #000000;
  line-height: 1;
}

.rem-unit {
  font-size: 28rpx;
  color: #4b5563;
  font-family: serif;
  font-style: italic;
  margin-left: 16rpx;
}

.info-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 48rpx;
  margin-bottom: 80rpx;
  border-bottom: 2rpx solid #e5e7eb;
  padding-bottom: 80rpx;
}

.info-item {
  display: flex;
  align-items: flex-start;
  gap: 24rpx;
}

.info-text-box {
  display: flex;
  flex-direction: column;
}

.info-label {
  font-size: 20rpx;
  color: #9ca3af;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  font-weight: 700;
  margin-bottom: 4rpx;
}

.info-value {
  font-size: 28rpx;
  color: #000000;
  font-weight: 500;
}

.detail-section {
  margin-bottom: 80rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #000000;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  margin-bottom: 32rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.section-desc {
  font-size: 28rpx;
  color: #374151;
  font-family: serif;
  line-height: 1.8;
  text-align: justify;
}

.req-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.req-item {
  display: flex;
  align-items: flex-start;
  gap: 24rpx;
}

.req-idx {
  font-size: 24rpx;
  font-family: serif;
  font-weight: 700;
  color: #d1d5db;
  font-style: italic;
  padding-top: 4rpx;
}

.req-text {
  font-size: 28rpx;
  color: #374151;
  line-height: 1.6;
}

.end-mark {
  margin-top: 64rpx;
  display: flex;
  justify-content: center;
}

.end-line {
  width: 48rpx;
  height: 2rpx;
  background-color: #000000;
}

/* Bottom Action Bar */
.bottom-action-bar {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20px);
  border-top: 2rpx solid #000000;
  padding: 32rpx 56rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  display: flex;
  justify-content: space-between;
  align-items: center;
  z-index: 50;
}

.bottom-cat-box {
  display: flex;
  flex-direction: column;
}

.bottom-cat-label {
  font-size: 20rpx;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: #9ca3af;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.bottom-cat-val {
  font-size: 28rpx;
  font-weight: 700;
  color: #000000;
}

.apply-btn {
  padding: 32rpx 64rpx;
  background-color: #000000;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  box-shadow: 12rpx 12rpx 0 rgba(0,0,0,0.1);
  transition: transform 0.1s, box-shadow 0.1s;
}

.apply-btn:active {
  transform: translateY(4rpx);
  box-shadow: 8rpx 8rpx 0 rgba(0,0,0,0.1);
}

/* ================= Clay Theme Overrides ================= */
page,
.page-root,
.view-container,
.bg-white {
  background-color: #f0f3f8;
  color: #5a6a85;
}

.animate-fade-slide {
  animation: slideUpFade 0.7s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}

.header-area {
  padding: 56rpx 56rpx 24rpx;
  align-items: center;
}

.header-subtitle,
.detail-en,
.info-label,
.bottom-cat-label,
.card-status,
.card-location,
.rem-label {
  color: #7a8b9e;
}

.header-title,
.detail-title-large,
.card-title,
.salary-val,
.rem-val,
.bottom-cat-val,
.info-value,
.section-title,
.req-text {
  color: #5a6a85;
}

.header-title,
.detail-title-large {
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, Arial, sans-serif;
  font-weight: 900;
  letter-spacing: 0;
}

.search-btn,
.back-btn,
.card-arrow {
  border: none;
  border-radius: 28rpx;
  background-color: #f0f3f8;
  box-shadow: 5px 5px 10px #d9dfe9, -5px -5px 10px #ffffff;
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.search-btn:active,
.back-btn:active,
.card-arrow:active {
  background-color: #f0f3f8;
  transform: scale(0.9);
  box-shadow: inset 4px 4px 8px #d9dfe9, inset -4px -4px 8px #ffffff;
}

.tabs-area {
  padding: 32rpx 56rpx 24rpx;
  border-bottom: none;
}

.tab-item {
  padding: 16rpx 28rpx;
  margin-right: 24rpx;
  border-radius: 24rpx;
  background-color: #f0f3f8;
  color: #7a8b9e;
  box-shadow: 4px 4px 8px #d9dfe9, -4px -4px 8px #ffffff;
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.tab-item.active {
  color: #ffffff;
  background-color: #ff9a9e;
  box-shadow: inset 4px 4px 8px #e68b8e, inset -4px -4px 8px #ffabae;
}

.tab-indicator {
  display: none;
}

.list-content {
  padding-top: 28rpx;
  gap: 40rpx;
}

.resource-card,
.detail-header-box,
.info-item,
.detail-section {
  border: none;
  border-radius: 48rpx;
  background-color: #f0f3f8;
  box-shadow: 12px 12px 24px #d9dfe9, -12px -12px 24px #ffffff;
}

.resource-card {
  padding: 44rpx 40rpx;
  margin-bottom: 0;
}

.resource-card:active {
  opacity: 1;
  transform: scale(0.98);
  box-shadow: inset 4px 4px 8px #d9dfe9, inset -4px -4px 8px #ffffff;
}

.card-category,
.status-dot {
  border: none;
  color: #ffffff;
  background-color: #ff9a9e;
  border-radius: 16rpx;
  box-shadow: inset 3px 3px 6px #e68b8e, inset -3px -3px 6px #ffabae;
}

.card-desc,
.section-desc,
.req-text,
.salary-unit,
.rem-unit {
  color: #7a8b9e;
}

.detail-header-box {
  padding: 48rpx;
  margin-bottom: 48rpx;
}

.info-grid {
  border-bottom: none;
  gap: 28rpx;
  padding-bottom: 48rpx;
  margin-bottom: 48rpx;
}

.info-item,
.detail-section {
  padding: 32rpx;
}

.req-idx {
  color: #a5b0c2;
}

.end-line {
  width: 256rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background-color: #d9dfe9;
}

.bottom-action-bar {
  left: 56rpx;
  right: 56rpx;
  bottom: calc(32rpx + env(safe-area-inset-bottom));
  border-top: none;
  border-radius: 40rpx;
  background-color: #f0f3f8;
  padding: 24rpx;
  box-shadow: 8px 8px 16px #d9dfe9, -8px -8px 16px #ffffff;
}

.apply-btn {
  border-radius: 32rpx;
  background-color: #a1c4fd;
  box-shadow: 8px 8px 20px #c2d8ff, -8px -8px 20px #ffffff;
}

.apply-btn:active {
  transform: scale(0.95);
  box-shadow: inset 4px 4px 8px #91b0e4, inset -4px -4px 8px #b1d8ff;
}

@keyframes slideUpFade {
  0% { opacity: 0; transform: translateY(40px); }
  100% { opacity: 1; transform: translateY(0); }
}
