/* pages/policy-detail/policy-detail.wxss */
page {
  background-color: #FFFFFF;
  height: 100vh;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, Segoe UI, Arial, Roboto, 'PingFang SC', 'miui', 'Hiragino Sans GB', 'Microsoft Yahei', sans-serif;
}

::-webkit-scrollbar {
  display: none;
  width: 0;
  height: 0;
  color: transparent;
}

.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  position: relative;
  overflow: hidden;
}

.container.no-scroll {
  overflow: hidden;
}

/* Detail Content */
.detail-scroll {
  flex: 1;
  height: 0; /* Important for flex: 1 scroll-view in WeChat */
  padding: 64rpx 64rpx 0;
  box-sizing: border-box;
}

.content-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.policy-en-title {
  font-size: 20rpx;
  letter-spacing: 0.2em;
  color: #9CA3AF;
  font-weight: bold;
  text-transform: uppercase;
  margin-bottom: 24rpx;
  text-align: center;
}

.policy-title {
  font-size: 56rpx;
  font-family: Georgia, 'Times New Roman', Times, serif;
  font-weight: bold;
  color: #000000;
  line-height: 1.2;
  text-align: center;
  margin-bottom: 28rpx;
}

.policy-actions {
  display: flex;
  justify-content: center;
  margin-bottom: 56rpx;
}

.favorite-btn {
  height: 64rpx;
  padding: 0 32rpx;
  border: 2rpx solid #000000;
  color: #000000;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.favorite-btn.active {
  background-color: #000000;
  color: #ffffff;
}

.tags-wrapper {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 80rpx;
}

.tag-item {
  padding: 8rpx 24rpx;
  background-color: #000000;
  color: #FFFFFF;
  font-size: 22rpx;
  font-weight: bold;
  letter-spacing: 0.1em;
  text-transform: uppercase;
}

.text-container {
  position: relative;
  width: 100%;
  padding-top: 48rpx;
}

.text-decorator {
  position: absolute;
  left: 0;
  top: 0;
  width: 64rpx;
  height: 2rpx;
  background-color: #000000;
}

.content-paragraph {
  font-size: 30rpx;
  color: #374151;
  font-family: Georgia, 'Times New Roman', Times, serif;
  line-height: 2.2;
  text-align: justify;
  display: block;
  margin-bottom: 28rpx;
  word-break: break-word;
}

.source-footer {
  width: 100%;
  margin-top: 48rpx;
  padding-top: 28rpx;
  border-top: 2rpx solid #E5E7EB;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  color: #9CA3AF;
  font-size: 22rpx;
  line-height: 1.6;
}

.source-link {
  word-break: break-all;
}

.end-mark {
  margin-top: 96rpx;
  display: flex;
  justify-content: center;
  gap: 8rpx;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  background-color: #000000;
  border-radius: 50%;
}

.dot-1 { opacity: 1; }
.dot-2 { opacity: 0.5; }
.dot-3 { opacity: 0.2; }

.bottom-spacer {
  height: 350rpx;
}

/* Minimalist AI Sticky Bar */
.ai-sticky-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #000000;
  color: #FFFFFF;
  padding: 48rpx 56rpx;
  z-index: 40;
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
}

.ai-sticky-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.ai-sticky-title {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 28rpx;
  font-weight: bold;
  letter-spacing: 0.1em;
}

.sparkle-icon {
  color: #FFFFFF;
}

.ai-sticky-subtitle {
  font-size: 20rpx;
  color: #9CA3AF;
  font-family: Georgia, 'Times New Roman', Times, serif;
  font-style: italic;
}

.ai-trigger-box {
  background-color: rgba(255, 255, 255, 0.1);
  border: 2rpx solid rgba(255, 255, 255, 0.2);
  height: 96rpx;
  padding: 0 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  transition: background-color 0.2s;
}

.ai-trigger-box:active {
  background-color: rgba(255, 255, 255, 0.2);
}

.ai-trigger-placeholder {
  color: #9CA3AF;
  font-size: 26rpx;
}

.ai-trigger-btn {
  width: 48rpx;
  height: 48rpx;
  background-color: #FFFFFF;
  color: #000000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.arrow-up {
  font-weight: bold;
  font-size: 28rpx;
}

/* Slide-up AI Chat Modal */
.ai-chat-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}

.ai-backdrop {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.6);
  backdrop-filter: blur(4px);
}

.ai-sheet {
  position: relative;
  width: 100%;
  height: 85%;
  background-color: #FFFFFF;
  border-top-left-radius: 48rpx;
  border-top-right-radius: 48rpx;
  display: flex;
  flex-direction: column;
  box-shadow: 0 -10rpx 40rpx rgba(0,0,0,0.2);
}

.ai-sheet-header {
  padding: 40rpx 48rpx;
  border-bottom: 2rpx solid #000000;
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-shrink: 0;
}

.ai-sheet-title {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 32rpx;
  font-weight: bold;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: #000000;
}

.sparkle-icon-dark {
  color: #000000;
}

.ai-sheet-close {
  padding: 8rpx;
  font-size: 36rpx;
  color: #000000;
}

/* Chat Messages Area */
.ai-messages-area {
  flex: 1;
  background-color: #FCFCFC;
  padding: 48rpx;
  box-sizing: border-box;
}

.messages-container {
  display: flex;
  flex-direction: column;
  gap: 48rpx;
  padding-bottom: 48rpx;
}

.msg-row {
  display: flex;
  width: 100%;
}

.msg-right {
  justify-content: flex-end;
}

.msg-left {
  justify-content: flex-start;
}

/* User Bubble (Solid Black) */
.bubble-user {
  background-color: #000000;
  color: #FFFFFF;
  padding: 24rpx 40rpx;
  max-width: 80%;
  font-size: 28rpx;
  line-height: 1.6;
  box-shadow: 8rpx 8rpx 0 rgba(0,0,0,0.1);
}

/* AI Bubble (Editorial Outline) */
.bubble-ai {
  background-color: #FFFFFF;
  border: 2rpx solid #D1D5DB;
  color: #1F2937;
  padding: 32rpx 40rpx;
  max-width: 90%;
  font-size: 28rpx;
  font-family: Georgia, 'Times New Roman', Times, serif;
  line-height: 1.8;
  position: relative;
  box-shadow: 0 2rpx 4rpx rgba(0,0,0,0.02);
}

.ai-quote-mark {
  position: absolute;
  top: -24rpx;
  left: -16rpx;
  background-color: #FFFFFF;
  padding: 0 8rpx;
  font-size: 28rpx;
  color: #9CA3AF;
}

/* Chat Input Bar */
.ai-input-bar {
  padding: 40rpx;
  background-color: #FFFFFF;
  border-top: 2rpx solid #E5E7EB;
  flex-shrink: 0;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.ai-input-wrapper {
  display: flex;
  align-items: flex-end;
  gap: 24rpx;
  border-bottom: 2rpx solid #000000;
  padding-bottom: 16rpx;
  transition: border-color 0.2s;
}

.ai-input-wrapper:focus-within {
  border-color: #000000;
}

.ai-input {
  flex: 1;
  font-size: 28rpx;
  color: #000000;
}

.ai-input-placeholder {
  color: #9CA3AF;
}

.ai-send-btn {
  width: 64rpx;
  height: 64rpx;
  background-color: #000000;
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8rpx;
  flex-shrink: 0;
}

.arrow-up-light {
  font-weight: bold;
  font-size: 32rpx;
}

/* Animations */
@keyframes slideUp {
  0% { transform: translateY(100%); }
  100% { transform: translateY(0); }
}
.animate-slide-up {
  animation: slideUp 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}

@keyframes fadeIn {
  0% { opacity: 0; }
  100% { opacity: 1; }
}
.animate-fade-in {
  animation: fadeIn 0.3s ease-out forwards;
}

/* Loading & Error */
.loading-state,
.error-state {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.loading-icon,
.error-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.loading-text,
.error-text {
  font-size: 28rpx;
  color: #9CA3AF;
}

.retry-btn {
  margin-top: 32rpx;
  padding: 16rpx 48rpx;
  background-color: #000000;
  color: #FFFFFF;
  font-size: 24rpx;
  letter-spacing: 0.1em;
  text-transform: uppercase;
}

/* ================= Clay Theme Overrides ================= */
page,
.container,
.ai-sheet,
.ai-messages-area,
.ai-input-bar {
  background-color: #f0f3f8;
  color: #5a6a85;
}

.policy-title,
.ai-sheet-title,
.ai-sticky-title,
.content-paragraph,
.source-footer,
.ai-trigger-placeholder,
.bubble-ai,
.ai-input,
.loading-text,
.error-text {
  color: #5a6a85;
}

.policy-en-title,
.source-footer,
.ai-sticky-subtitle,
.ai-input-placeholder {
  color: #7a8b9e;
}

.detail-scroll {
  padding: 64rpx 56rpx 0;
}

.policy-title {
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, Arial, sans-serif;
  font-weight: 900;
  letter-spacing: 0;
}

.favorite-btn,
.tag-item,
.text-container,
.ai-sticky-bar,
.ai-trigger-box,
.ai-send-btn,
.bubble-user,
.bubble-ai,
.retry-btn {
  border: none;
  border-radius: 32rpx;
  background-color: #f0f3f8;
  box-shadow: 8px 8px 16px #d9dfe9, -8px -8px 16px #ffffff;
}

.favorite-btn {
  color: #7a8b9e;
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.favorite-btn.active,
.tag-item {
  background-color: #ff9a9e;
  color: #ffffff;
  box-shadow: inset 4px 4px 8px #e68b8e, inset -4px -4px 8px #ffabae;
}

.favorite-btn:active {
  transform: scale(0.95);
  box-shadow: inset 4px 4px 8px #d9dfe9, inset -4px -4px 8px #ffffff;
}

.text-container {
  padding: 44rpx 36rpx;
}

.text-decorator,
.dot {
  background-color: #d9dfe9;
}

.source-footer {
  border-top-color: #d9dfe9;
}

.ai-sticky-bar {
  left: 56rpx;
  right: 56rpx;
  bottom: calc(32rpx + env(safe-area-inset-bottom));
  padding: 32rpx;
  color: #5a6a85;
}

.sparkle-icon,
.sparkle-icon-dark {
  color: #ff9a9e;
}

.ai-trigger-box {
  height: 96rpx;
  box-shadow: inset 4px 4px 8px #d9dfe9, inset -4px -4px 8px #ffffff;
}

.ai-trigger-box:active {
  background-color: #f0f3f8;
  transform: scale(0.98);
}

.ai-trigger-btn,
.ai-send-btn {
  background-color: #a1c4fd;
  color: #ffffff;
  border-radius: 24rpx;
  box-shadow: 8px 8px 20px #c2d8ff, -8px -8px 20px #ffffff;
}

.ai-backdrop {
  background-color: rgba(240, 243, 248, 0.8);
  backdrop-filter: blur(8px);
}

.ai-sheet {
  border-top-left-radius: 64rpx;
  border-top-right-radius: 64rpx;
  box-shadow: -12px -12px 24px rgba(255,255,255,0.95), 0 -12px 30px rgba(217,223,233,0.9);
}

.ai-sheet-header,
.ai-input-bar {
  border-color: #d9dfe9;
}

.ai-sheet-close {
  width: 64rpx;
  height: 64rpx;
  border-radius: 20rpx;
  background-color: #f0f3f8;
  color: #7a8b9e;
  box-shadow: 4px 4px 8px #d9dfe9, -4px -4px 8px #ffffff;
}

.bubble-user {
  background-color: #a1c4fd;
  color: #ffffff;
  box-shadow: 8px 8px 20px #c2d8ff, -8px -8px 20px #ffffff;
}

.bubble-ai {
  color: #5a6a85;
}

.ai-input-wrapper {
  border-bottom: none;
  border-radius: 24rpx;
  padding: 20rpx 24rpx;
  background-color: #f0f3f8;
  box-shadow: inset 4px 4px 8px #d9dfe9, inset -4px -4px 8px #ffffff;
}

.retry-btn {
  color: #ffffff;
  background-color: #a1c4fd;
  box-shadow: 8px 8px 20px #c2d8ff, -8px -8px 20px #ffffff;
}
