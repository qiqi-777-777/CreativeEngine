/* pages/login/login.wxss */
page {
  background-color: #f0f3f8;
  height: 100vh;
  overflow: hidden;
}

view, scroll-view, text, input, button {
  box-sizing: border-box;
}

.font-serif {
  font-family: serif, 'Georgia', 'Times New Roman', 'PingFang SC', 'Microsoft YaHei', sans-serif;
}

.font-sans {
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, 'PingFang SC', 'Microsoft YaHei', sans-serif;
}

.container {
  width: 100%;
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f0f3f8;
  color: #5a6a85;
}

.status-bar {
  width: 100%;
}

.nav-bar {
  height: 44px;
  width: 100%;
  display: flex;
  align-items: center;
  padding: 0 16px;
  flex-shrink: 0;
}

.nav-back {
  width: 48px;
  height: 48px;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  border-radius: 18px;
  background-color: #f0f3f8;
  box-shadow: 5px 5px 10px #d9dfe9, -5px -5px 10px #ffffff;
  transition: all 0.3s;
}

.nav-back:active {
  background-color: #f0f3f8;
  transform: scale(0.9);
  box-shadow: inset 4px 4px 8px #d9dfe9, inset -4px -4px 8px #ffffff;
}

.nav-back:active .nav-back-icon {
  color: #7a8b9e;
}

.nav-back-icon {
  font-size: 24px;
  color: #7a8b9e;
  line-height: 1;
  margin-bottom: 2px;
}

.content-scroll {
  flex: 1;
  height: 0;
}

.no-scrollbar::-webkit-scrollbar {
  display: none;
}

/* ================== Hero Section ================== */
.hero-section {
  padding: 40px 24px 32px;
  display: flex;
  flex-direction: column;
  animation: slideUpFade 0.7s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}

.hero-label {
  font-size: 10px;
  letter-spacing: 3px;
  color: #7a8b9e;
  text-transform: uppercase;
  margin-bottom: 20px;
}

.hero-title {
  font-size: 44px;
  font-weight: 700;
  color: #5a6a85;
  line-height: 1.15;
}

.hero-subtitle {
  font-size: 13px;
  color: #7a8b9e;
  margin-top: 16px;
  letter-spacing: 0.5px;
}

/* ================== Form Section ================== */
.form-section {
  padding: 8px 24px 0;
  animation: slideUpFade 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.12s forwards;
  opacity: 0;
}

.form-item {
  margin-bottom: 28px;
}

.form-label {
  font-size: 11px;
  font-weight: 600;
  color: #7a8b9e;
  text-transform: uppercase;
  letter-spacing: 1px;
  margin-bottom: 12px;
  display: block;
}

.form-input {
  width: 100%;
  height: 48px;
  border: none;
  border-radius: 18px;
  font-size: 16px;
  color: #5a6a85;
  padding: 0 16px;
  background: #f0f3f8;
  box-shadow: inset 4px 4px 8px #d9dfe9, inset -4px -4px 8px #ffffff;
  transition: border-color 0.3s;
}

.form-input:focus {
  box-shadow: inset 5px 5px 10px #d9dfe9, inset -5px -5px 10px #ffffff;
}

.form-placeholder {
  color: #a5b0c2;
}

.login-btn {
  width: 100%;
  height: 52px;
  background-color: #a1c4fd;
  color: #ffffff;
  border: none;
  border-radius: 24px;
  font-size: 15px;
  font-weight: 600;
  letter-spacing: 4px;
  margin-top: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s;
  box-shadow: 8px 8px 20px #c2d8ff, -8px -8px 20px #ffffff;
}

.login-btn:active {
  transform: scale(0.95);
  box-shadow: inset 4px 4px 8px #91b0e4, inset -4px -4px 8px #b1d8ff;
}

.login-btn[disabled] {
  background-color: #f0f3f8;
  color: #7a8b9e;
  box-shadow: 8px 8px 16px #d9dfe9, -8px -8px 16px #ffffff;
}

.register-link {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 24px;
  gap: 6px;
}

.register-text {
  font-size: 13px;
  color: #7a8b9e;
}

.register-action {
  font-size: 13px;
  color: #5a6a85;
  font-weight: 600;
  letter-spacing: 0.5px;
}

/* ================== Divider ================== */
.divider-section {
  display: flex;
  align-items: center;
  padding: 32px 24px;
  gap: 16px;
}

.divider-line {
  flex: 1;
  height: 1px;
  background-color: #d9dfe9;
}

.divider-text {
  font-size: 10px;
  color: #a5b0c2;
  letter-spacing: 2px;
  font-weight: 600;
}

/* ================== WeChat Login ================== */
.wechat-section {
  padding: 0 24px;
}

.wechat-btn {
  width: 100%;
  height: 52px;
  background-color: #f0f3f8;
  color: #5a6a85;
  border: none;
  border-radius: 24px;
  font-size: 14px;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  transition: all 0.3s;
  padding: 0;
  line-height: 52px;
  box-shadow: 8px 8px 16px #d9dfe9, -8px -8px 16px #ffffff;
}

.wechat-btn::after {
  border: none;
}

.wechat-btn:active {
  background-color: #f0f3f8;
  color: #5a6a85;
  transform: scale(0.96);
  box-shadow: inset 4px 4px 8px #d9dfe9, inset -4px -4px 8px #ffffff;
}

.wechat-icon-box {
  width: 22px;
  height: 22px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.wechat-icon {
  width: 22px;
  height: 22px;
}

/* ================== Agreement ================== */
.agreement-section {
  display: flex;
  align-items: flex-start;
  padding: 28px 24px 0;
  gap: 8px;
}

.agreement-check {
  flex-shrink: 0;
  margin-top: 1px;
}

.checkbox {
  transform: scale(0.7);
}

.agreement-text {
  font-size: 11px;
  color: #7a8b9e;
  line-height: 1.6;
}

.agreement-link {
  color: #5a6a85;
  font-weight: 500;
}

@keyframes slideUpFade {
  0% { opacity: 0; transform: translateY(40px); }
  100% { opacity: 1; transform: translateY(0); }
}
