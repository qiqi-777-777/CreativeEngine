<!--pages/login/login.wxml-->
<view class="container font-serif">
  <view class="status-bar" style="height: {{statusBarHeight}}px;"></view>

  <!-- Custom Nav Bar -->
  <view class="nav-bar">
    <view class="nav-back" bindtap="onBack">
      <text class="nav-back-icon">‹</text>
    </view>
  </view>

  <scroll-view scroll-y class="content-scroll no-scrollbar">
    <!-- Hero Title -->
    <view class="hero-section">
      <text class="hero-label font-sans">CREATIVE ENGINE</text>
      <text class="hero-title">Welcome</text>
      <text class="hero-title">Back.</text>
      <text class="hero-subtitle font-sans">登录您的账号，继续创业之旅</text>
    </view>

    <!-- Form -->
    <view class="form-section font-sans">
      <view class="form-item">
        <text class="form-label">用户名</text>
        <input
          class="form-input"
          type="text"
          placeholder="请输入用户名"
          placeholder-class="form-placeholder"
          value="{{username}}"
          bindinput="onUsernameInput"
          maxlength="20"
        />
      </view>

      <view class="form-item">
        <text class="form-label">密码</text>
        <input
          class="form-input"
          type="password"
          placeholder="请输入密码"
          placeholder-class="form-placeholder"
          value="{{password}}"
          bindinput="onPasswordInput"
          maxlength="50"
        />
      </view>

      <button class="login-btn" bindtap="login" disabled="{{!agreed || username.length < 3 || password.length < 6}}">
        登 录
      </button>

      <view class="register-link">
        <text class="register-text">还没有账号？</text>
        <text class="register-action" bindtap="goToRegister">立即注册 →</text>
      </view>
    </view>

    <!-- Divider -->
    <view class="divider-section font-sans">
      <view class="divider-line"></view>
      <text class="divider-text">OR</text>
      <view class="divider-line"></view>
    </view>

    <!-- WeChat Login -->
    <view class="wechat-section font-sans">
      <button
        class="wechat-btn"
        open-type="getUserProfile"
        bindgetuserprofile="wechatLogin"
      >
        <view class="wechat-icon-box">
          <image class="wechat-icon" src="/images/wechat-icon.png" mode="aspectFit"></image>
        </view>
        <text>微信快速登录</text>
      </button>
    </view>

    <!-- Agreement -->
    <view class="agreement-section font-sans">
      <checkbox-group bindchange="onAgreementChange" class="agreement-check">
        <checkbox class="checkbox" checked="{{agreed}}" color="#000000"/>
      </checkbox-group>
      <view class="agreement-text">
        我已阅读并同意
        <text class="agreement-link" bindtap="showUserAgreement">《用户协议》</text>
        和
        <text class="agreement-link" bindtap="showPrivacyPolicy">《隐私政策》</text>
      </view>
    </view>

    <view style="height: 80px;"></view>
  </scroll-view>
</view>
