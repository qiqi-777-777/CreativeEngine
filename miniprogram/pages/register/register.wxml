<!--pages/register/register.wxml-->
<view class="container font-serif">
  <view class="status-bar" style="height: {{statusBarHeight}}px;"></view>

  <!-- Custom Nav Bar -->
  <view class="nav-bar">
    <view class="nav-back" bindtap="onBack">
      <text class="nav-back-icon">‹</text>
    </view>
  </view>

  <scroll-view scroll-y class="content-scroll no-scrollbar">
    <!-- Hero Title -->
    <view class="hero-section">
      <text class="hero-label font-sans">CREATIVE ENGINE</text>
      <text class="hero-title">Create</text>
      <text class="hero-title">Account.</text>
      <text class="hero-subtitle font-sans">加入创享引擎，开启创业之旅</text>
    </view>

    <!-- Form -->
    <view class="form-section font-sans">
      <view class="form-item">
        <text class="form-label">用户名 <text class="required">*</text></text>
        <input
          class="form-input"
          type="text"
          placeholder="3-20个字符，支持字母数字下划线"
          placeholder-class="form-placeholder"
          value="{{username}}"
          bindinput="onUsernameInput"
          maxlength="20"
        />
      </view>

      <view class="form-item">
        <text class="form-label">密码 <text class="required">*</text></text>
        <input
          class="form-input"
          type="password"
          placeholder="至少6位字符"
          placeholder-class="form-placeholder"
          value="{{password}}"
          bindinput="onPasswordInput"
          maxlength="50"
        />
      </view>

      <view class="form-item">
        <text class="form-label">确认密码 <text class="required">*</text></text>
        <input
          class="form-input"
          type="password"
          placeholder="请再次输入密码"
          placeholder-class="form-placeholder"
          value="{{confirmPassword}}"
          bindinput="onConfirmPasswordInput"
          maxlength="50"
        />
      </view>

      <view class="form-item">
        <text class="form-label">昵称</text>
        <input
          class="form-input"
          type="text"
          placeholder="显示名称，不填则使用用户名"
          placeholder-class="form-placeholder"
          value="{{nickname}}"
          bindinput="onNicknameInput"
          maxlength="20"
        />
      </view>

      <view class="form-item">
        <text class="form-label">邮箱</text>
        <input
          class="form-input"
          type="text"
          placeholder="用于找回密码和接收通知"
          placeholder-class="form-placeholder"
          value="{{email}}"
          bindinput="onEmailInput"
          maxlength="50"
        />
      </view>

      <button
        class="register-btn"
        bindtap="register"
        disabled="{{!agreed || username.length < 3 || password.length < 6 || password !== confirmPassword}}"
      >
        注 册
      </button>

      <view class="login-link">
        <text class="login-text">已有账号？</text>
        <text class="login-action" bindtap="goToLogin">立即登录 →</text>
      </view>
    </view>

    <!-- Agreement -->
    <view class="agreement-section font-sans">
      <checkbox-group bindchange="onAgreementChange" class="agreement-check">
        <checkbox class="checkbox" checked="{{agreed}}" color="#000000"/>
      </checkbox-group>
      <view class="agreement-text">
        我已阅读并同意
        <text class="agreement-link" bindtap="showUserAgreement">《用户协议》</text>
        和
        <text class="agreement-link" bindtap="showPrivacyPolicy">《隐私政策》</text>
      </view>
    </view>

    <view style="height: 80px;"></view>
  </scroll-view>
</view>
