/* pages/register/register.wxss */
page {
  background-color: #ffffff;
  height: 100vh;
  overflow: hidden;
}

view, scroll-view, text, input, button {
  box-sizing: border-box;
}

.font-serif {
  font-family: serif, 'Georgia', 'Times New Roman', 'PingFang SC', 'Microsoft YaHei', sans-serif;
}

.font-sans {
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, 'PingFang SC', 'Microsoft YaHei', sans-serif;
}

.container {
  width: 100%;
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #ffffff;
  color: #000000;
}

.status-bar {
  width: 100%;
}

.nav-bar {
  height: 44px;
  width: 100%;
  display: flex;
  align-items: center;
  padding: 0 16px;
  flex-shrink: 0;
}

.nav-back {
  width: 36px;
  height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1px solid #e5e7eb;
  border-radius: 50%;
  transition: all 0.3s;
}

.nav-back:active {
  background-color: #000;
  border-color: #000;
}

.nav-back:active .nav-back-icon {
  color: #fff;
}

.nav-back-icon {
  font-size: 24px;
  color: #000;
  line-height: 1;
  margin-bottom: 2px;
}

.content-scroll {
  flex: 1;
  height: 0;
}

.no-scrollbar::-webkit-scrollbar {
  display: none;
}

/* ================== Hero Section ================== */
.hero-section {
  padding: 32px 24px 24px;
  display: flex;
  flex-direction: column;
}

.hero-label {
  font-size: 10px;
  letter-spacing: 3px;
  color: #9ca3af;
  text-transform: uppercase;
  margin-bottom: 16px;
}

.hero-title {
  font-size: 40px;
  font-weight: 700;
  color: #000000;
  line-height: 1.15;
}

.hero-subtitle {
  font-size: 13px;
  color: #6b7280;
  margin-top: 14px;
  letter-spacing: 0.5px;
}

/* ================== Form Section ================== */
.form-section {
  padding: 4px 24px 0;
}

.form-item {
  margin-bottom: 22px;
}

.form-label {
  font-size: 11px;
  font-weight: 600;
  color: #9ca3af;
  text-transform: uppercase;
  letter-spacing: 1px;
  margin-bottom: 10px;
  display: block;
}

.required {
  color: #000;
  font-weight: 700;
}

.form-input {
  width: 100%;
  height: 44px;
  border: none;
  border-bottom: 1px solid #e5e7eb;
  font-size: 15px;
  color: #000000;
  padding: 0;
  background: transparent;
  transition: border-color 0.3s;
}

.form-input:focus {
  border-bottom-color: #000000;
}

.form-placeholder {
  color: #d1d5db;
  font-size: 13px;
}

.register-btn {
  width: 100%;
  height: 52px;
  background-color: #000000;
  color: #ffffff;
  border: none;
  border-radius: 9999px;
  font-size: 15px;
  font-weight: 600;
  letter-spacing: 4px;
  margin-top: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s;
}

.register-btn:active {
  opacity: 0.85;
  transform: scale(0.98);
}

.register-btn[disabled] {
  background-color: #e5e7eb;
  color: #9ca3af;
}

.login-link {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 24px;
  gap: 6px;
}

.login-text {
  font-size: 13px;
  color: #9ca3af;
}

.login-action {
  font-size: 13px;
  color: #000000;
  font-weight: 600;
  letter-spacing: 0.5px;
}

/* ================== Agreement ================== */
.agreement-section {
  display: flex;
  align-items: flex-start;
  padding: 24px 24px 0;
  gap: 8px;
}

.agreement-check {
  flex-shrink: 0;
  margin-top: 1px;
}

.checkbox {
  transform: scale(0.7);
}

.agreement-text {
  font-size: 11px;
  color: #9ca3af;
  line-height: 1.6;
}

.agreement-link {
  color: #000000;
  font-weight: 500;
}
