/* pages/career-match/career-match.wxss */
page {
  background-color: #f0f3f8;
  height: 100vh;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, Segoe UI, Arial, Roboto, 'PingFang SC', 'miui', 'Hiragino Sans GB', 'Microsoft Yahei', sans-serif;
  color: #5a6a85;
  -webkit-tap-highlight-color: transparent;
}

::-webkit-scrollbar {
  display: none;
  width: 0;
  height: 0;
  color: transparent;
}

button {
  margin: 0;
  padding: 0;
  border: none;
  outline: none;
  line-height: normal;
  background: transparent;
  -webkit-tap-highlight-color: transparent;
}

button::after {
  border: none;
}

.page-container {
  width: 100vw;
  height: 100vh;
  display: flex;
  flex-direction: column;
  position: relative;
  overflow: hidden;
}

/* Animations */
@keyframes slideUpFade {
  0% { opacity: 0; transform: translateY(40px); }
  100% { opacity: 1; transform: translateY(0); }
}

.animate-slide-up-fade {
  animation: slideUpFade 0.7s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  opacity: 0;
}

@keyframes popBounce {
  0% { transform: scale(0.5); opacity: 0; }
  50% { transform: scale(1.2); }
  100% { transform: scale(1); opacity: 1; }
}

.animate-pop-bounce {
  animation: popBounce 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
}

/* Custom Navigation Bar */
.nav-bar {
  display: flex;
  align-items: center;
  padding: 0 48rpx 16rpx;
  position: relative;
  z-index: 40;
  flex-shrink: 0;
  height: 96rpx;
  box-sizing: content-box;
}

.clay-btn-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 36rpx;
  background-color: #f0f3f8;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 5px 5px 10px #d9dfe9, -5px -5px 10px #ffffff;
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  margin-left: -16rpx;
}

.clay-btn-icon:active {
  transform: scale(0.9);
  box-shadow: inset 4px 4px 8px #d9dfe9, inset -4px -4px 8px #ffffff;
}

.back-icon {
  width: 24rpx;
  height: 24rpx;
  border-top: 4rpx solid #7a8b9e;
  border-left: 4rpx solid #7a8b9e;
  transform: rotate(-45deg);
  margin-left: 8rpx;
}

/* Main Content */
.main-content {
  flex: 1;
  height: 0;
  padding: 48rpx 56rpx 320rpx;
  box-sizing: border-box;
}

/* Editorial Title */
.editorial-header {
  margin-bottom: 80rpx;
}

.zh-title {
  font-size: 68rpx;
  font-weight: 900;
  color: #5a6a85;
  letter-spacing: 0;
  display: block;
  margin-bottom: 16rpx;
}

.desc-text {
  font-size: 28rpx;
  color: #7a8b9e;
  font-weight: 500;
  display: block;
}

/* Sections */
.section {
  margin-bottom: 64rpx;
}

.clay-card {
  background-color: #f0f3f8;
  border-radius: 64rpx;
  padding: 56rpx;
  box-shadow: 12px 12px 24px #d9dfe9, -12px -12px 24px #ffffff;
}

.section-header {
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #7a8b9e;
}

.tags-scroll {
  width: 100%;
  white-space: nowrap;
  overflow: hidden;
  padding: 6rpx 0 18rpx;
}

.tags-wrap {
  display: inline-grid;
  grid-template-rows: repeat(4, max-content);
  grid-auto-flow: column;
  grid-auto-columns: max-content;
  gap: 28rpx;
  padding: 8rpx 18rpx 8rpx 4rpx;
}

.tag-item {
  padding: 24rpx 40rpx;
  font-size: 28rpx;
  font-weight: bold;
  border-radius: 32rpx;
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background-color: #f0f3f8;
  color: #7a8b9e;
  box-shadow: 4px 4px 8px #d9dfe9, -4px -4px 8px #ffffff, inset -2px -2px 4px rgba(0,0,0,0.02), inset 2px 2px 4px #ffffff;
}

.tag-item:active {
  transform: scale(0.88);
}

.tag-selected {
  background-color: #ff9a9e !important;
  color: #ffffff !important;
  box-shadow: inset 4px 4px 8px #e68b8e, inset -4px -4px 8px #ffabae !important;
  transform: scale(0.96);
}

/* Helper Link */
.helper-link {
  margin-top: 48rpx;
  display: inline-block;
}

.helper-link text {
  font-size: 24rpx;
  color: #7a8b9e;
  font-weight: bold;
  text-decoration: underline;
  text-underline-offset: 8rpx;
}

/* Bottom Action Bar */
.bottom-bar-wrapper {
  position: absolute;
  bottom: calc(64rpx + env(safe-area-inset-bottom));
  left: 64rpx;
  right: 64rpx;
  z-index: 50;
}

.match-btn {
  width: 100%;
  padding: 32rpx 0;
  border-radius: 48rpx;
  font-weight: 900;
  font-size: 36rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 24rpx;
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.match-btn:active {
  transform: scale(0.95);
}

.inactive-btn {
  background-color: #f0f3f8;
  color: #7a8b9e;
  box-shadow: 8px 8px 16px #d9dfe9, -8px -8px 16px #ffffff;
}

.inactive-btn:active {
  box-shadow: inset 4px 4px 8px #d9dfe9, inset -4px -4px 8px #ffffff;
}

.active-btn {
  background-color: #a1c4fd;
  color: #ffffff;
  box-shadow: 8px 8px 20px #c2d8ff, -8px -8px 20px #ffffff;
}

.active-btn:active {
  box-shadow: inset 4px 4px 8px #91b0e4, inset -4px -4px 8px #b1d8ff;
}

.badge {
  background-color: rgba(255,255,255,0.3);
  padding: 4rpx 20rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  box-shadow: inset 1px 1px 2px rgba(255,255,255,0.4), inset -1px -1px 2px rgba(0,0,0,0.05);
}

.home-indicator {
  position: absolute;
  bottom: calc(16rpx + env(safe-area-inset-bottom));
  left: 50%;
  width: 256rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background-color: #d9dfe9;
  transform: translateX(-50%);
  z-index: 100;
}

/* Modal Styling */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(240, 243, 248, 0.8);
  backdrop-filter: blur(8px);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.personality-modal {
  width: 85%;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-bottom: 32rpx;
  border-bottom: 2rpx solid #d9dfe9;
  margin-bottom: 32rpx;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 900;
  color: #5a6a85;
}

.clay-btn-icon-small {
  width: 64rpx;
  height: 64rpx;
  border-radius: 20rpx;
  background-color: #f0f3f8;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 4px 4px 8px #d9dfe9, -4px -4px 8px #ffffff;
  transition: all 0.3s;
  color: #7a8b9e;
  font-weight: bold;
}

.clay-btn-icon-small:active {
  transform: scale(0.9);
  box-shadow: inset 4px 4px 8px #d9dfe9, inset -4px -4px 8px #ffffff;
}

.personality-content {
  max-height: 60vh;
}

.personality-detail-item {
  padding: 32rpx 0;
  border-bottom: 2rpx solid #e2e8f0;
}

.personality-detail-item:last-child {
  border-bottom: none;
}

.personality-type {
  font-size: 32rpx;
  font-weight: 900;
  color: #5a6a85;
  margin-bottom: 16rpx;
}

.personality-desc {
  font-size: 28rpx;
  color: #7a8b9e;
  margin-bottom: 16rpx;
  line-height: 1.6;
}

.personality-traits {
  font-size: 28rpx;
  color: #7a8b9e;
  line-height: 1.6;
}

.trait-label {
  color: #5a6a85;
  font-weight: bold;
}
