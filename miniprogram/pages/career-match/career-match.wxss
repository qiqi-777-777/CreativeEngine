/* pages/career-match/career-match.wxss */
page {
  background: #ffffff;
  color: #000000;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
}

::-webkit-scrollbar {
  display: none;
  width: 0;
  height: 0;
  color: transparent;
}

.page-container {
  width: 100vw;
  height: 100vh;
  display: flex;
  flex-direction: column;
  position: relative;
  overflow: hidden;
}

/* Custom Navigation Bar */
.nav-bar {
  display: flex;
  align-items: center;
  padding: 0 40rpx 20rpx;
  position: relative;
  z-index: 40;
  flex-shrink: 0;
  height: 88rpx; /* Standard nav bar height */
  box-sizing: content-box;
}

.nav-back {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  margin-left: -16rpx;
}

.back-icon {
  width: 24rpx;
  height: 24rpx;
  border-top: 3rpx solid #000;
  border-left: 3rpx solid #000;
  transform: rotate(-45deg);
}

.nav-title {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  font-size: 30rpx;
  font-weight: 500;
  letter-spacing: 4rpx;
  color: #000;
}

/* Main Content */
.main-content {
  flex: 1;
  height: 0;
  padding: 48rpx 56rpx 280rpx;
  box-sizing: border-box;
}

/* Editorial Title */
.editorial-header {
  margin-bottom: 96rpx;
  border-bottom: 2rpx solid #000;
  padding-bottom: 64rpx;
}

.en-subtitle {
  font-size: 22rpx;
  letter-spacing: 0.3em;
  color: #9CA3AF;
  font-weight: 700;
  text-transform: uppercase;
  margin-bottom: 24rpx;
  display: block;
}

.zh-title {
  font-size: 84rpx;
  font-family: Georgia, 'Times New Roman', Times, serif;
  font-weight: 700;
  color: #000;
  line-height: 1;
  letter-spacing: -2rpx;
  display: block;
}

.desc-text {
  margin-top: 32rpx;
  font-size: 26rpx;
  color: #6B7280;
  line-height: 1.6;
  font-family: Georgia, 'Times New Roman', Times, serif;
  font-style: italic;
  max-width: 85%;
  display: block;
}

/* Sections */
.section {
  margin-bottom: 80rpx;
}

.section-header {
  display: flex;
  align-items: baseline;
  gap: 32rpx;
  margin-bottom: 48rpx;
}

.section-id {
  font-size: 40rpx;
  font-family: Georgia, 'Times New Roman', Times, serif;
  color: #D1D5DB;
  font-style: italic;
}

.section-title-wrap {
  display: flex;
  flex-direction: column;
}

.section-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #000;
  letter-spacing: 2rpx;
}

.section-en {
  font-size: 18rpx;
  letter-spacing: 0.2em;
  color: #9CA3AF;
  text-transform: uppercase;
  margin-top: 8rpx;
}

.tags-scroll {
  width: 100%;
  white-space: nowrap;
}

.tags-grid {
  display: inline-grid;
  grid-template-rows: repeat(4, max-content);
  grid-auto-columns: max-content;
  grid-auto-flow: column;
  gap: 20rpx;
  padding-bottom: 20rpx; /* Prevent shadow clipping on bottom elements */
}

.tag-item {
  padding: 16rpx 32rpx;
  font-size: 26rpx;
  font-weight: 500;
  border-radius: 4rpx;
  border: 2rpx solid #E5E7EB;
  background: transparent;
  color: #4B5563;
  transition: all 0.3s;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.tag-item:active {
  background: #f3f4f6;
}

.tag-selected {
  background: #000 !important;
  border-color: #000 !important;
  color: #fff !important;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
}

.divider {
  width: 100%;
  height: 2rpx;
  background: #F3F4F6;
  margin-top: 80rpx;
}

/* Helper Link */
.helper-link {
  margin-top: 48rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding-bottom: 4rpx;
  border-bottom: 2rpx solid #D1D5DB;
  align-self: flex-start;
  width: max-content;
}

.helper-link text {
  font-size: 24rpx;
  color: #9CA3AF;
}

.arrow-right-icon {
  width: 12rpx;
  height: 12rpx;
  border-top: 2rpx solid #9CA3AF;
  border-right: 2rpx solid #9CA3AF;
  transform: rotate(45deg);
  margin-left: 8rpx;
}

/* Bottom Action Bar */
.bottom-bar {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  border-top: 2rpx solid #000;
  padding: 40rpx 56rpx 80rpx; /* Extra bottom padding for iPhone indicator */
  display: flex;
  justify-content: space-between;
  align-items: center;
  z-index: 50;
}

.selected-info {
  display: flex;
  flex-direction: column;
}

.info-label {
  font-size: 22rpx;
  letter-spacing: 0.1em;
  color: #6B7280;
  text-transform: uppercase;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.info-value-wrap {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.info-count {
  font-size: 48rpx;
  font-family: Georgia, 'Times New Roman', Times, serif;
  font-weight: 700;
  color: #000;
  line-height: 1;
}

.info-placeholder {
  font-size: 24rpx;
  color: #9CA3AF;
  font-family: Georgia, 'Times New Roman', Times, serif;
  font-style: italic;
  margin-left: 8rpx;
}

.match-btn {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 32rpx 64rpx;
  background: #000;
  color: #fff;
  font-size: 30rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
  border-radius: 0;
  transition: all 0.2s;
  box-shadow: 16rpx 16rpx 0 rgba(0,0,0,0.1);
}

.match-btn:active {
  transform: scale(0.95);
}

.match-btn.disabled {
  opacity: 0.5;
  box-shadow: none;
}

.btn-arrow {
  width: 16rpx;
  height: 16rpx;
  border-top: 4rpx solid #fff;
  border-right: 4rpx solid #fff;
  transform: rotate(45deg);
}

/* Modal Styling from original but slightly adapted to fit minimal theme */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.55);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.personality-modal {
  width: 86%;
  max-height: 80vh;
  background: #fff;
  border-radius: 0;
  overflow: hidden;
  box-shadow: 0 12rpx 36rpx rgba(0, 0, 0, 0.2);
  border: 2rpx solid #000;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 40rpx;
  border-bottom: 2rpx solid #000;
  background: #000;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 2rpx;
}

.close-btn {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 32rpx;
}

.personality-content {
  max-height: 60vh;
  padding: 40rpx;
  box-sizing: border-box;
  background: #fff;
}

.personality-detail-item {
  padding: 32rpx 0;
  border-bottom: 2rpx solid #F3F4F6;
}

.personality-detail-item:last-child {
  border-bottom: none;
}

.personality-type {
  font-size: 32rpx;
  font-weight: 700;
  color: #000;
  margin-bottom: 12rpx;
}

.personality-desc {
  font-size: 28rpx;
  color: #6B7280;
  margin-bottom: 12rpx;
  line-height: 1.6;
}

.personality-traits {
  font-size: 28rpx;
  color: #4B5563;
  line-height: 1.6;
}

.trait-label {
  color: #000;
  font-weight: 700;
}
