<!--pages/career-match/career-match.wxml-->
<wxs module="tools">
var isSelected = function(category, item, majors, skills, personalities) {
  if (category === 'major') {
    return majors.indexOf(item) !== -1;
  } else if (category === 'skill') {
    return skills.indexOf(item) !== -1;
  } else if (category === 'personality') {
    for (var i = 0; i < personalities.length; i++) {
        if (personalities[i] === item) return true;
        if (typeof personalities[i] === 'string' && typeof item === 'object' && item.type) {
            if (personalities[i] === item.type) return true;
        }
        if (typeof personalities[i] === 'object' && typeof item === 'string' && personalities[i].type) {
            if (personalities[i].type === item) return true;
        }
        if (typeof personalities[i] === 'object' && typeof item === 'object' && personalities[i].type && item.type) {
            if (personalities[i].type === item.type) return true;
        }
    }
    return false;
  }
  return false;
};
module.exports = {
  isSelected: isSelected
};
</wxs>

<view class="page-container">
  <!-- Custom Navigation Bar -->
  <view class="nav-bar" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-back clay-btn-icon" bindtap="goBack">
      <view class="back-icon"></view>
    </view>
  </view>

  <scroll-view class="main-content" scroll-y="true" enable-flex="true">
    <!-- Editorial Title Section -->
    <view class="editorial-header">
      <text class="zh-title animate-slide-up-fade" style="animation-delay: 0ms">职业匹配</text>
      <text class="desc-text animate-slide-up-fade" style="animation-delay: 100ms">轻触模块，构建你的多维画像</text>
    </view>

    <!-- 1. Major Section -->
    <view class="section clay-card animate-slide-up-fade" style="animation-delay: 200ms">
      <view class="section-header">
        <text class="section-title">专业</text>
      </view>
      <scroll-view class="tags-scroll" scroll-x="true" enhanced show-scrollbar="{{false}}">
        <view class="tags-wrap">
          <view
            wx:for="{{majorOptions}}"
            wx:key="*this"
            class="tag-item {{tools.isSelected('major', item, selectedMajors, selectedSkills, selectedPersonalities) ? 'tag-selected' : ''}}"
            bindtap="onOptionTap"
            data-category="major"
            data-item="{{item}}"
          >
            {{item}}
          </view>
        </view>
      </scroll-view>
    </view>

    <!-- 2. Skill Section -->
    <view class="section clay-card animate-slide-up-fade" style="animation-delay: 300ms">
      <view class="section-header">
        <text class="section-title">技术</text>
      </view>
      <scroll-view class="tags-scroll" scroll-x="true" enhanced show-scrollbar="{{false}}">
        <view class="tags-wrap">
          <view
            wx:for="{{skillOptions}}"
            wx:key="*this"
            class="tag-item {{tools.isSelected('skill', item, selectedMajors, selectedSkills, selectedPersonalities) ? 'tag-selected' : ''}}"
            bindtap="onOptionTap"
            data-category="skill"
            data-item="{{item}}"
          >
            {{item}}
          </view>
        </view>
      </scroll-view>
    </view>

    <!-- 3. Personality Section -->
    <view class="section clay-card animate-slide-up-fade" style="animation-delay: 400ms">
      <view class="section-header">
        <text class="section-title">性格</text>
      </view>
      <scroll-view class="tags-scroll" scroll-x="true" enhanced show-scrollbar="{{false}}">
        <view class="tags-wrap">
          <view
            wx:for="{{personalityDetails}}"
            wx:key="type"
            class="tag-item {{tools.isSelected('personality', item.type, selectedMajors, selectedSkills, selectedPersonalities) ? 'tag-selected' : ''}}"
            bindtap="onOptionTap"
            data-category="personality"
            data-item="{{item.type}}"
          >
            {{item.type}}
          </view>
        </view>
      </scroll-view>

      <view class="helper-link" bindtap="showPersonalityDetail">
        <text>查看性格详细说明</text>
      </view>
    </view>
  </scroll-view>

  <!-- Bottom Action Bar -->
  <view class="bottom-bar-wrapper animate-slide-up-fade" style="animation-delay: 600ms">
    <button class="match-btn {{totalSelected > 0 ? 'active-btn' : 'inactive-btn'}}" bindtap="onMatch">
      开始匹配
      <view class="badge {{badgeAnimateClass}}" wx:if="{{totalSelected > 0}}">{{totalSelected}}</view>
    </button>
  </view>

  <view class="home-indicator"></view>

  <!-- Personality Modal -->
  <view class="modal-overlay" wx:if="{{showPersonalityModal}}" catchtap="hidePersonalityDetail">
    <view class="personality-modal clay-card" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">性格类型说明</text>
        <view class="close-btn clay-btn-icon-small" bindtap="hidePersonalityDetail">✕</view>
      </view>
      <scroll-view class="personality-content" scroll-y="true">
        <view class="personality-detail-item" wx:for="{{personalityDetails}}" wx:key="type">
          <view class="personality-type">{{item.type}}</view>
          <view class="personality-desc">{{item.description}}</view>
          <view class="personality-traits">
            <text class="trait-label">特征：</text>
            <text class="trait-text">{{item.traits}}</text>
          </view>
        </view>
        <view style="height: 40rpx;"></view>
      </scroll-view>
    </view>
  </view>
</view>
