<!--pages/career-match/career-match.wxml-->
<wxs module="tools">
var isSelected = function(category, item, majors, skills, personalities) {
  if (category === 'major') {
    return majors.indexOf(item) !== -1;
  } else if (category === 'skill') {
    return skills.indexOf(item) !== -1;
  } else if (category === 'personality') {
    for (var i = 0; i < personalities.length; i++) {
        if (personalities[i] === item) return true;
        if (typeof personalities[i] === 'string' && typeof item === 'object' && item.type) {
            if (personalities[i] === item.type) return true;
        }
        if (typeof personalities[i] === 'object' && typeof item === 'string' && personalities[i].type) {
            if (personalities[i].type === item) return true;
        }
        if (typeof personalities[i] === 'object' && typeof item === 'object' && personalities[i].type && item.type) {
            if (personalities[i].type === item.type) return true;
        }
    }
    return false;
  }
  return false;
};
module.exports = {
  isSelected: isSelected
};
</wxs>

<view class="page-container">
  <!-- Custom Navigation Bar -->
  <view class="nav-bar" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-back" bindtap="goBack">
      <view class="back-icon"></view>
    </view>
    <text class="nav-title">AI职业匹配</text>
  </view>

  <scroll-view class="main-content" scroll-y="true">
    <!-- Editorial Title Section -->
    <view class="editorial-header">
      <text class="en-subtitle">Career Match</text>
      <text class="zh-title">职业匹配.</text>
      <text class="desc-text">Select your competencies and traits below to initiate the AI-driven career alignment protocol.</text>
    </view>

    <!-- 1. Major Section -->
    <view class="section">
      <view class="section-header">
        <text class="section-id">01</text>
        <view class="section-title-wrap">
          <text class="section-title">专业</text>
          <text class="section-en">MAJOR & CERT.</text>
        </view>
      </view>
      <scroll-view class="tags-scroll" scroll-x="true" show-scrollbar="false">
        <view class="tags-grid">
          <view
            wx:for="{{majorOptions}}"
            wx:key="*this"
            class="tag-item {{tools.isSelected('major', item, selectedMajors, selectedSkills, selectedPersonalities) ? 'tag-selected' : ''}}"
            bindtap="onOptionTap"
            data-category="major"
            data-item="{{item}}"
          >
            {{item}}
          </view>
        </view>
      </scroll-view>
      <view class="divider"></view>
    </view>

    <!-- 2. Skill Section -->
    <view class="section">
      <view class="section-header">
        <text class="section-id">02</text>
        <view class="section-title-wrap">
          <text class="section-title">技术</text>
          <text class="section-en">TECHNICAL SKILLS</text>
        </view>
      </view>
      <scroll-view class="tags-scroll" scroll-x="true" show-scrollbar="false">
        <view class="tags-grid">
          <view
            wx:for="{{skillOptions}}"
            wx:key="*this"
            class="tag-item {{tools.isSelected('skill', item, selectedMajors, selectedSkills, selectedPersonalities) ? 'tag-selected' : ''}}"
            bindtap="onOptionTap"
            data-category="skill"
            data-item="{{item}}"
          >
            {{item}}
          </view>
        </view>
      </scroll-view>
      <view class="divider"></view>
    </view>

    <!-- 3. Personality Section -->
    <view class="section">
      <view class="section-header">
        <text class="section-id">03</text>
        <view class="section-title-wrap">
          <text class="section-title">性格</text>
          <text class="section-en">PERSONALITY TRAITS</text>
        </view>
      </view>
      <scroll-view class="tags-scroll" scroll-x="true" show-scrollbar="false">
        <view class="tags-grid">
          <view
            wx:for="{{personalityDetails}}"
            wx:key="type"
            class="tag-item {{tools.isSelected('personality', item.type, selectedMajors, selectedSkills, selectedPersonalities) ? 'tag-selected' : ''}}"
            bindtap="onOptionTap"
            data-category="personality"
            data-item="{{item.type}}"
          >
            {{item.type}}
          </view>
        </view>
      </scroll-view>

      <view class="helper-link" bindtap="showPersonalityDetail">
        <text>查看性格详细说明</text>
        <view class="arrow-right-icon"></view>
      </view>
    </view>
  </scroll-view>

  <!-- Bottom Action Bar -->
  <view class="bottom-bar">
    <view class="selected-info">
      <text class="info-label">已选要素</text>
      <view class="info-value-wrap">
        <text class="info-count">{{totalSelected > 0 ? totalSelected : '0'}}</text>
        <text class="info-placeholder" wx:if="{{totalSelected === 0}}">期待你的选择</text>
      </view>
    </view>
    <view class="match-btn {{totalSelected === 0 ? 'disabled' : ''}}" bindtap="onMatch">
      <text>开始匹配</text>
      <view class="btn-arrow"></view>
    </view>
  </view>

  <!-- Personality Modal -->
  <view class="modal-overlay" wx:if="{{showPersonalityModal}}" catchtap="hidePersonalityDetail">
    <view class="personality-modal" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">性格类型说明</text>
        <view class="close-btn" bindtap="hidePersonalityDetail">✕</view>
      </view>
      <scroll-view class="personality-content" scroll-y="true">
        <view class="personality-detail-item" wx:for="{{personalityDetails}}" wx:key="type">
          <view class="personality-type">{{item.type}}</view>
          <view class="personality-desc">{{item.description}}</view>
          <view class="personality-traits">
            <text class="trait-label">特征：</text>
            <text class="trait-text">{{item.traits}}</text>
          </view>
        </view>
        <view style="height: 40rpx;"></view>
      </scroll-view>
    </view>
  </view>
</view>
